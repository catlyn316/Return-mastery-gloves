local function runAutoAbility()
    while toggles.autoAbility do
        task.wait(values.abilityInterval)
        if not toggles.autoAbility then break end
        pcall(function() ReplicatedStorage.GeneralAbility:FireServer(0.3) end)
    end
end

local function runAutoAttack()
    while toggles.autoAttack do
        if not toggles.autoAbility then
            task.wait(0.5)
        else
            -- 等自動能力冷卻完，再延 1.5 秒補攻擊
            task.wait(values.abilityInterval + 1.5)
            if not toggles.autoAttack then break end
            pcall(function()
                local nearest = getNearestTarget()
                if nearest and nearest.Character then
                    local torso = nearest.Character:FindFirstChild("Torso")
                    if torso then ReplicatedStorage.GeneralHit:FireServer(torso) end
                end
            end)
        end
    end
end

