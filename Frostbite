-- ============================================================
-- 輔助函數
-- ============================================================
local function getNearestTarget()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = char.HumanoidRootPart.Position
    local nearest, minDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (p.Character.HumanoidRootPart.Position - myPos).Magnitude
            if d < minDist then minDist = d; nearest = p end
        end
    end
    return nearest
end

-- ── 移速套用 ──
local function applySpeed(char)
    if not char then char = player.Character end
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    if connections.speed then connections.speed:Disconnect(); connections.speed = nil end
    if toggles.speed then
        hum.WalkSpeed = values.speed
        connections.speed = hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
            if toggles.speed then hum.WalkSpeed = values.speed end
        end)
    else
        hum.WalkSpeed = originalSpeed
    end
end

-- ── 確認裝備 Frostbite ──
local function ensureFrostbite(callback)
    task.spawn(function()
        local function getGlove()
            for _, name in ipairs({"leaderstats","Leaderboard","leaderboard"}) do
                local lb = player:FindFirstChild(name)
                if lb then
                    local g = lb:FindFirstChild("Glove")
                    if g then return g.Value end
                end
            end
            return nil
        end

        if getGlove() == "Frostbite" then
            if callback then callback() end
            return
        end

        pcall(function() player.Reset:FireServer() end)

        local timeout = tick()
        while tick() - timeout < 15 do
            task.wait(0.2)
            local hasTool = false
            local char = player.Character
            if char then
                for _, obj in ipairs(char:GetChildren()) do
                    if obj:IsA("Tool") then hasTool = true; break end
                end
            end
            local bp = player:FindFirstChildOfClass("Backpack")
            if bp then
                for _, obj in ipairs(bp:GetChildren()) do
                    if obj:IsA("Tool") then hasTool = true; break end
                end
            end
            if not hasTool then
                task.wait(0.3)
                pcall(function()
                    fireclickdetector(Workspace.Lobby["Frostbite"].ClickDetector)
                end)
                break
            end
        end

        if callback then callback() end
    end)
end

-- ============================================================
-- 範圍圓指示器（手動模式專用）
-- 半徑 45 studs：紅 = 範圍內 <3 人，綠 = ≥3 人
-- ============================================================
local circleIndicator = nil

local function createCircleIndicator()
    if circleIndicator then circleIndicator:Destroy() end

    local part = Instance.new("Part")
    part.Name        = "FrostCircle"
    part.Shape       = Enum.PartType.Cylinder
    part.Size        = Vector3.new(0.3, 90, 90)
    part.Anchored    = true
    part.CanCollide  = false
    pcall(function() part.CanQuery = false end)
    part.Material    = Enum.Material.Neon
    part.Transparency = 0.65
    part.Color       = Color3.fromRGB(200, 45, 45)
    part.CastShadow  = false
    part.Parent      = Workspace
    circleIndicator  = part

    connections.circle = RunService.Heartbeat:Connect(function()
        local char = player.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        local hrp = char.HumanoidRootPart

        part.CFrame = CFrame.new(hrp.Position.X, hrp.Position.Y - 3, hrp.Position.Z)
            * CFrame.Angles(0, 0, math.rad(90))

        local count = 0
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                if (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude <= 45 then
                    count = count + 1
                end
            end
        end

        if count >= 3 then
            part.Color        = Color3.fromRGB(45, 200, 45)
            part.Transparency = 0.55
        else
            part.Color        = Color3.fromRGB(200, 45, 45)
            part.Transparency = 0.65
        end
    end)
end

local function destroyCircleIndicator()
    if connections.circle then
        connections.circle:Disconnect()
        connections.circle = nil
    end
    if circleIndicator then
        circleIndicator:Destroy()
        circleIndicator = nil
    end
end

-- ============================================================
-- ESP + 面向面板（手動模式開啟時建立，關閉時銷毀）
-- ============================================================
local espPanelGui          = nil
local espPanelConnections  = {}
local espCleanupFn         = nil

local function destroyESPPanel()
    if espCleanupFn then
        pcall(espCleanupFn)
        espCleanupFn = nil
    end
    for _, conn in ipairs(espPanelConnections) do
        pcall(function()
            if typeof(conn) == "RBXScriptConnection" then conn:Disconnect() end
        end)
    end
    espPanelConnections = {}
    if espPanelGui and espPanelGui.Parent then
        espPanelGui:Destroy()
        espPanelGui = nil
    end
end

local function createESPPanel()
    destroyESPPanel()

    task.spawn(function()
        pcall(function()
            local Tw  = game:GetService("TweenService")
            local Plrs = Players
            local RS   = RunService
            local Wk   = Workspace
            local plr  = player

            local gui = Instance.new("ScreenGui")
            gui.Name            = "FrostESPUI"
            gui.ResetOnSpawn    = false
            gui.IgnoreGuiInset  = true
            gui.ZIndexBehavior  = Enum.ZIndexBehavior.Global
            gui.DisplayOrder    = 10002

            local function parentG(g)
                local ok = false
                if not ok then ok = pcall(function()
                    if type(gethui)=="function" then g.Parent=gethui() else error() end
                end) end
                if not ok then ok = pcall(function() g.Parent = CoreGui end) end
                if not ok then g.Parent = playerGui end
            end
            parentG(gui)
            espPanelGui = gui

            local lockMode        = "none"
            local rotCon          = nil
            local mouseClickConn  = nil
            local targetPlayer    = nil
            local lastClickTime   = 0
            local lastClickedPlayer = nil

            local nearBtn, clickBtn, espBtnRef, centerBtn

            local espEnabled = false
            local espLabels  = {}
            local espBoxes   = {}
            local espConn    = nil

            local function updateButtonState(button, active)
                if not (button and button.Parent) then return end
                Tw:Create(button, TweenInfo.new(0.2), {
                    BackgroundColor3 = active
                        and Color3.fromRGB(50,100,150)
                        or  Color3.fromRGB(40,40,45)
                }):Play()
                local s = button:FindFirstChild("BtnStroke")
                if s then
                    Tw:Create(s, TweenInfo.new(0.2), {
                        Color     = active and Color3.fromRGB(0,200,255) or Color3.fromRGB(80,80,90),
                        Thickness = active and 2 or 1
                    }):Play()
                end
            end

            local function getParts()
                local c   = plr.Character
                if not c then return nil, nil, nil end
                local hum = c:FindFirstChildOfClass("Humanoid")
                local hrp = c:FindFirstChild("HumanoidRootPart")
                return c, hum, hrp
            end

            local function clearAllModes()
                if rotCon          then rotCon:Disconnect();         rotCon         = nil end
                if mouseClickConn  then mouseClickConn:Disconnect(); mouseClickConn = nil end
                pcall(function()
                    local _, h, _ = getParts()
                    if h then h.AutoRotate = true end
                end)
                updateButtonState(nearBtn,   false)
                updateButtonState(clickBtn,  false)
                updateButtonState(centerBtn, false)
                lockMode          = "none"
                targetPlayer      = nil
                lastClickedPlayer = nil
            end

            local function cleanupESP(p)
                if espLabels[p] then
                    if espLabels[p].billboard then espLabels[p].billboard:Destroy() end
                    espLabels[p] = nil
                end
                if espBoxes[p] then espBoxes[p]:Destroy(); espBoxes[p] = nil end
            end

            espCleanupFn = function()
                clearAllModes()
                if espConn then espConn:Disconnect(); espConn = nil end
                for p in pairs(espLabels) do cleanupESP(p) end
            end

            local function setFaceRotation(ftype, target)
                if rotCon then rotCon:Disconnect(); rotCon = nil end
                pcall(function()
                    local _, h, _ = getParts()
                    if h then h.AutoRotate = false end
                end)

                rotCon = RS.RenderStepped:Connect(function()
                    pcall(function()
                        local _, _, myHRP = getParts()
                        if not myHRP then return end
                        local lookAt = nil

                        if ftype == "nearest" then
                            local nearest, minD = nil, math.huge
                            for _, p in ipairs(Plrs:GetPlayers()) do
                                if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                                    local d = (myHRP.Position - p.Character.HumanoidRootPart.Position).Magnitude
                                    if d < minD then minD = d; nearest = p.Character.HumanoidRootPart end
                                end
                            end
                            if nearest then lookAt = nearest.Position end

                        elseif ftype == "click" and target and target.Character then
                            local pr = target.Character:FindFirstChild("HumanoidRootPart")
                            if pr then lookAt = pr.Position end

                        elseif ftype == "center" then
                            lookAt = Vector3.new(0, myHRP.Position.Y, 0)
                        end

                        if lookAt then
                            local flat = (lookAt - myHRP.Position) * Vector3.new(1,0,1)
                            if flat.Magnitude > 0.001 then
                                myHRP.CFrame = CFrame.lookAt(
                                    myHRP.Position,
                                    myHRP.Position + flat.Unit,
                                    Vector3.yAxis
                                )
                            end
                        end
                    end)
                end)
            end

            local panelWidth = 80
            local btnH       = 30
            local btnGap     = 3
            local numBtns    = 4
            local expandedH  = numBtns * btnH + (numBtns - 1) * btnGap
            local toggleBtnH = 28

            local panel = Instance.new("Frame")
            panel.Name             = "ESPAnchor"
            panel.AnchorPoint      = Vector2.new(1, 1)
            panel.Size             = UDim2.fromOffset(panelWidth, toggleBtnH)
            panel.Position         = UDim2.new(1, -36, 1, -50)
            panel.BackgroundTransparency = 1
            panel.ClipsDescendants = false
            panel.Parent           = gui

            local toggleBtn = Instance.new("TextButton")
            toggleBtn.AnchorPoint       = Vector2.new(0, 1)
            toggleBtn.Size              = UDim2.fromOffset(panelWidth, toggleBtnH)
            toggleBtn.Position          = UDim2.new(0, 0, 1, 0)
            toggleBtn.BackgroundColor3  = Color3.fromRGB(45,45,55)
            toggleBtn.Text              = "面向/ESP ▲"
            toggleBtn.TextSize          = 11
            toggleBtn.Font              = Enum.Font.GothamBold
            toggleBtn.TextColor3        = Color3.fromRGB(200,200,220)
            toggleBtn.AutoButtonColor   = false
            toggleBtn.Parent            = panel
            Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0,6)

            local xBtn = Instance.new("TextButton")
            xBtn.Size              = UDim2.fromOffset(22, 22)
            xBtn.AnchorPoint       = Vector2.new(0, 1)
            xBtn.Position          = UDim2.new(1, 4, 1, -3)
            xBtn.BackgroundColor3  = Color3.fromRGB(200,50,50)
            xBtn.Text              = "x"
            xBtn.TextSize          = 13
            xBtn.Font              = Enum.Font.GothamBold
            xBtn.TextColor3        = Color3.new(1,1,1)
            xBtn.AutoButtonColor   = false
            xBtn.Parent            = panel
            Instance.new("UICorner", xBtn).CornerRadius = UDim.new(0,5)

            local btnContainer = Instance.new("Frame")
            btnContainer.AnchorPoint        = Vector2.new(0,1)
            btnContainer.Size               = UDim2.fromOffset(panelWidth, 0)
            btnContainer.Position           = UDim2.new(0,0,1,-toggleBtnH)
            btnContainer.BackgroundTransparency = 1
            btnContainer.ClipsDescendants   = true
            btnContainer.Parent             = panel

            local function createExtraBtn(name, idx)
                local b = Instance.new("TextButton")
                b.Name              = name
                b.Size              = UDim2.fromOffset(panelWidth, btnH)
                b.Position          = UDim2.fromOffset(0, (idx-1)*(btnH+btnGap))
                b.BackgroundColor3  = Color3.fromRGB(38,38,48)
                b.Text              = name
                b.TextSize          = 11
                b.TextColor3        = Color3.new(1,1,1)
                b.AutoButtonColor   = false
                b.Parent            = btnContainer
                Instance.new("UICorner", b).CornerRadius = UDim.new(0,6)
                local s = Instance.new("UIStroke")
                s.Thickness = 1; s.Color = Color3.fromRGB(70,70,85)
                s.Name = "BtnStroke"; s.Parent = b
                return b
            end

            espBtnRef = createExtraBtn("ESP",      1)
            nearBtn   = createExtraBtn("面向最近",  2)
            clickBtn  = createExtraBtn("面向雙擊",  3)
            centerBtn = createExtraBtn("朝向中央",  4)

            local isExpanded = false
            local function setExpanded(expand)
                isExpanded = expand
                local h = expand and expandedH or 0
                Tw:Create(btnContainer, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {
                    Size = UDim2.fromOffset(panelWidth, h)
                }):Play()
                Tw:Create(panel, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {
                    Size = UDim2.fromOffset(panelWidth, toggleBtnH + h)
                }):Play()
                toggleBtn.Text = expand and "面向/ESP ▼" or "面向/ESP ▲"
            end

            local isDragging   = false
            local dragMoved    = false
            local dragStartPos = nil
            local panelStart   = nil

            toggleBtn.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    isDragging   = true
                    dragMoved    = false
                    dragStartPos = input.Position
                    panelStart   = panel.Position
                    input.Changed:Connect(function()
                        if input.UserInputState == Enum.UserInputState.End then
                            isDragging = false
                        end
                    end)
                end
            end)

            local uisMove = UserInputService.InputChanged:Connect(function(input)
                if isDragging and (
                    input.UserInputType == Enum.UserInputType.MouseMovement or
                    input.UserInputType == Enum.UserInputType.Touch
                ) then
                    local delta = input.Position - dragStartPos
                    if delta.Magnitude > 5 then
                        dragMoved = true
                        panel.Position = UDim2.new(
                            panelStart.X.Scale, panelStart.X.Offset + delta.X,
                            panelStart.Y.Scale, panelStart.Y.Offset + delta.Y
                        )
                    end
                end
            end)
            table.insert(espPanelConnections, uisMove)

            local uisEnd = UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    isDragging = false
                end
            end)
            table.insert(espPanelConnections, uisEnd)

            toggleBtn.MouseButton1Click:Connect(function()
                if not dragMoved then setExpanded(not isExpanded) end
                dragMoved = false
            end)

            nearBtn.MouseButton1Click:Connect(function()
                if lockMode == "nearest" then
                    clearAllModes()
                else
                    clearAllModes()
                    lockMode = "nearest"
                    updateButtonState(nearBtn, true)
                    setFaceRotation("nearest")
                end
            end)

            clickBtn.MouseButton1Click:Connect(function()
                if lockMode == "click" then
                    clearAllModes()
                else
                    clearAllModes()
                    lockMode = "click"
                    updateButtonState(clickBtn, true)
                    mouseClickConn = plr:GetMouse().Button1Down:Connect(function()
                        local mouse = plr:GetMouse()
                        local cam   = Wk.CurrentCamera
                        local ray   = cam:ScreenPointToRay(mouse.X, mouse.Y)
                        local found, minDist = nil, math.huge
                        for _, p in ipairs(Plrs:GetPlayers()) do
                            if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                                local hrp  = p.Character.HumanoidRootPart
                                local toP  = hrp.Position - ray.Origin
                                local proj = toP:Dot(ray.Direction.Unit)
                                if proj > 0 then
                                    local closest = ray.Origin + ray.Direction.Unit * proj
                                    local dist    = (hrp.Position - closest).Magnitude
                                    if dist < 8 and proj < minDist then
                                        minDist = proj; found = p
                                    end
                                end
                            end
                        end
                        if found and found ~= plr then
                            local now = tick()
                            if lastClickedPlayer == found and (now - lastClickTime) < 0.5 then
                                targetPlayer = found
                                setFaceRotation("click", found)
                            end
                            lastClickedPlayer = found
                            lastClickTime     = now
                        end
                    end)
                end
            end)

            centerBtn.MouseButton1Click:Connect(function()
                if lockMode == "center" then
                    clearAllModes()
                else
                    clearAllModes()
                    lockMode = "center"
                    updateButtonState(centerBtn, true)
                    setFaceRotation("center")
                end
            end)

            espBtnRef.MouseButton1Click:Connect(function()
                espEnabled = not espEnabled
                updateButtonState(espBtnRef, espEnabled)
                if not espEnabled then
                    if espConn then espConn:Disconnect(); espConn = nil end
                    for p in pairs(espLabels) do cleanupESP(p) end
                else
                    espConn = RS.RenderStepped:Connect(function()
                        pcall(function()
                            local _, _, myHRP = getParts()
                            for _, p in ipairs(Plrs:GetPlayers()) do
                                if p ~= plr then
                                    local char = p.Character
                                    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                                    local hum  = char and char:FindFirstChildOfClass("Humanoid")
                                    if char and hrp and hum and hum.Health > 0 then
                                        if not espLabels[p] then
                                            local bg = Instance.new("BillboardGui")
                                            bg.Size         = UDim2.fromOffset(200, 70)
                                            bg.AlwaysOnTop  = true
                                            bg.StudsOffset  = Vector3.new(0, 3, 0)
                                            bg.Parent       = gui
                                            local tl = Instance.new("TextLabel")
                                            tl.Size                = UDim2.fromScale(1,1)
                                            tl.BackgroundTransparency = 1
                                            tl.TextColor3          = Color3.new(1,1,1)
                                            tl.TextStrokeTransparency = 0.5
                                            tl.TextSize            = 14
                                            tl.Font                = Enum.Font.SourceSansBold
                                            tl.TextXAlignment      = Enum.TextXAlignment.Center
                                            tl.Parent              = bg
                                            espLabels[p] = {billboard = bg, label = tl}
                                        end
                                        if not espBoxes[p] then
                                            local box = Instance.new("BoxHandleAdornment")
                                            box.Name         = "ESPBox"
                                            box.AlwaysOnTop  = true
                                            box.ZIndex       = 1
                                            box.Transparency = 0.7
                                            box.Color3       = Color3.new(1,1,1)
                                            box.Parent       = gui
                                            espBoxes[p] = box
                                        end
                                        local glove, slaps = "?", "?"
                                        local ls = p:FindFirstChild("leaderstats")
                                        if ls then
                                            local g = ls:FindFirstChild("Glove")
                                            local s = ls:FindFirstChild("Slaps")
                                            if g then glove = tostring(g.Value) end
                                            if s then slaps = tostring(s.Value) end
                                        end
                                        local dist = myHRP and (myHRP.Position - hrp.Position).Magnitude or 0
                                        local lab  = espLabels[p]
                                        lab.billboard.Adornee = hrp
                                        lab.label.Text = string.format(
                                            "名: %s\n%s / %s\n血量: %.0f/%.0f\n距離: %.1f",
                                            p.Name, glove, slaps,
                                            hum.Health, hum.MaxHealth, dist
                                        )
                                        espBoxes[p].Adornee = char
                                        espBoxes[p].Size    = char:GetExtentsSize()
                                    else
                                        cleanupESP(p)
                                    end
                                end
                            end
                            for p in pairs(espLabels) do
                                if not Plrs:FindFirstChild(p.Name) then cleanupESP(p) end
                            end
                        end)
                    end)
                end
            end)

            xBtn.MouseButton1Click:Connect(function()
                clearAllModes()
                if espConn then espConn:Disconnect(); espConn = nil end
                for p in pairs(espLabels) do cleanupESP(p) end
                if gui and gui.Parent then gui:Destroy(); espPanelGui = nil end
                espCleanupFn = nil
            end)

            local charAddConn = plr.CharacterAdded:Connect(function()
                task.wait(0.5)
                if lockMode ~= "none" then
                    setFaceRotation(lockMode, targetPlayer)
                end
            end)
            table.insert(espPanelConnections, charAddConn)
        end)
    end)
end

