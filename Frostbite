-- 關閉
-- ============================================================
closeButton.MouseButton1Click:Connect(function()
    for k, conn in pairs(connections) do
        if conn then
            pcall(function()
                if type(conn) == "thread" then task.cancel(conn)
                else conn:Disconnect() end
            end)
            connections[k] = nil
        end
    end
    destroyManualBtn()
    destroyCircleIndicator()
    destroyESPPanel()
    screenGui:Destroy()
end)

