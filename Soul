-- 第一、三任務：souls < 100 → GeneralHit；souls >= 100 → 等幫助者條件（最短5秒）→ Ability(true)
local function runQuest13()
    while toggles.attacker do
        local char = player.Character
        if not char then task.wait(0.2) continue end

        local souls = char:GetAttribute("souls") or 0

        if souls < 100 then
            local torso = getNearestTargetTorso()
            if torso then
                pcall(function()
                    ReplicatedStorage.GeneralHit:FireServer(torso)
                end)
            end
            task.wait(0.8)
        else
            -- souls >= 100，最短等 5 秒，且幫助者非 ragdoll 且在範圍內才發動
            local abilityDist = 15
            local function helperReady()
                local myChar = player.Character
                local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
                if not myHrp then return false end
                local nearestP, minDist = nil, math.huge
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        local d = (p.Character.HumanoidRootPart.Position - myHrp.Position).Magnitude
                        if d < minDist then minDist = d; nearestP = p end
                    end
                end
                if not nearestP then return false end
                if isPlayerRagdoll(nearestP) then return false end
                return minDist <= abilityDist
            end

            -- 最多等 5 秒，幫助者到了可提前發動
            local waitTimeout = tick() + 5
            while toggles.attacker and tick() < waitTimeout do
                if helperReady() then break end
                task.wait(0.1)
            end
            if not toggles.attacker then break end

            pcall(function()
                ReplicatedStorage.GeneralAbility:FireServer(true)
            end)
            task.wait(0.1)
            -- 等 souls 重置
            local timeout = tick() + 5
            while toggles.attacker and tick() < timeout do
                local c = player.Character
                if c and (c:GetAttribute("souls") or 0) < 100 then break end
                task.wait(0.1)
            end
        end
    end
end

-- 第二任務：souls < 100 → GeneralHit；souls >= 100 → charge；charge = 100 → Ability(true)
local function runQuest2()
    while toggles.attacker do
        local char = player.Character
        if not char then task.wait(0.2) continue end

        local souls = char:GetAttribute("souls") or 0

        if souls < 100 then
            -- 攻擊最近目標直到 souls >= 100
            local torso = getNearestTargetTorso()
            if torso then
                pcall(function()
                    ReplicatedStorage.GeneralHit:FireServer(torso)
                end)
            end
            task.wait(0.8)
        else
            -- 開始充能
            local charge = char:GetAttribute("charge") or 0
            if charge < 100 then
                pcall(function()
                    local eventsFolder = ReplicatedStorage:FindFirstChild("Events")
                    if eventsFolder then
                        local soulRemote = eventsFolder:FindFirstChild("soul")
                        if soulRemote then
                            soulRemote:FireServer("charge")
                        end
                    end
                end)
                task.wait(0.05)
            else
                -- charge = 100，等幫助者（最近玩家）從 ragdoll 恢復且在 15 單位內再發動能力
                local function helperReadyToAbility()
                    local myChar = player.Character
                    local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
                    if not myHrp then return false end
                    -- 找最近玩家
                    local nearestP = nil
                    local minDist = math.huge
                    for _, p in ipairs(Players:GetPlayers()) do
                        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                            local d = (p.Character.HumanoidRootPart.Position - myHrp.Position).Magnitude
                            if d < minDist then
                                minDist = d
                                nearestP = p
                            end
                        end
                    end
                    if not nearestP then return false end
                    -- 非 ragdoll 且在 15 單位內
                    if isPlayerRagdoll(nearestP) then return false end
                    return minDist <= 15
                end

                -- 等待條件成立（最多等 3 秒）
                local waitTimeout = tick() + 3
                while toggles.attacker and tick() < waitTimeout do
                    if helperReadyToAbility() then break end
                    task.wait(0.1)
                end

                if not toggles.attacker then break end

                -- 發動能力
                pcall(function()
                    ReplicatedStorage.GeneralAbility:FireServer(true)
                end)
                task.wait(0.1)
                -- 等待 souls 和 charge 重置後繼續
                local timeout = tick() + 5
                while toggles.attacker and tick() < timeout do
                    local c = player.Character
                    if c then
                        local s = c:GetAttribute("souls") or 0
                        local ch = c:GetAttribute("charge") or 0
                        if s < 100 or ch < 100 then break end
                    end
                    task.wait(0.1)
                end
            end
        end
    end
end

-- 第四任務：GeneralHit → 等目標非 ragdoll → GeneralAbility(false) → 等幫助者非 ragdoll → 重複
local function runQuest4()
    while toggles.attacker do
        -- 找最近目標
        local nearestPlayer = nil
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local myPos = char.HumanoidRootPart.Position
            local minDist = math.huge
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Torso") then
                    local d = (p.Character.HumanoidRootPart.Position - myPos).Magnitude
                    if d < minDist then
                        minDist = d
                        nearestPlayer = p
                    end
                end
            end
        end

        if nearestPlayer and nearestPlayer.Character then
            local torso = nearestPlayer.Character:FindFirstChild("Torso")
            if torso then
                -- 記錄打擊前的 Slaps 數值
                local slapsBefore = 0
                pcall(function()
                    local ls = player.leaderstats
                    if ls and ls:FindFirstChild("Slaps") then
                        slapsBefore = ls.Slaps.Value
                    end
                end)

                -- 攻擊
                pcall(function()
                    ReplicatedStorage.GeneralHit:FireServer(torso)
                end)

                task.wait(0.3)

                -- 檢查 Slaps 是否有增加，沒有則補點擊畫面
                local slapsAfter = 0
                pcall(function()
                    local ls = player.leaderstats
                    if ls and ls:FindFirstChild("Slaps") then
                        slapsAfter = ls.Slaps.Value
                    end
                end)

                if slapsAfter <= slapsBefore then
                    -- Slaps 沒變，直接再補打一次
                    pcall(function()
                        ReplicatedStorage.GeneralHit:FireServer(torso)
                    end)
                    task.wait(0.3)
                end

                task.wait(0.05)

                -- 等目標不是 ragdoll（最多等 5 秒）
                local waitTimeout = tick() + 5
                while toggles.attacker and tick() < waitTimeout do
                    if not isPlayerRagdoll(nearestPlayer) then break end
                    task.wait(0.05)
                end

                if not toggles.attacker then break end

                -- 發動能力
                pcall(function()
                    ReplicatedStorage.GeneralAbility:FireServer(false)
                end)

                -- 等幫助者（最近玩家）從 ragdoll 恢復後再繼續（最多等 8 秒）
                local helper = nil
                local myChar = player.Character
                local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
                if myHrp then
                    local minDist2 = math.huge
                    for _, p in ipairs(Players:GetPlayers()) do
                        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                            local d = (p.Character.HumanoidRootPart.Position - myHrp.Position).Magnitude
                            if d < minDist2 then minDist2 = d; helper = p end
                        end
                    end
                end
                if helper then
                    local helperTimeout = tick() + 8
                    while toggles.attacker and tick() < helperTimeout do
                        if not isPlayerRagdoll(helper) then break end
                        task.wait(0.05)
                    end
                end

                task.wait(0.5)
            else
                task.wait(0.1)
            end
        else
            task.wait(0.1)
        end
    end
end

