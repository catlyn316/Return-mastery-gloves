-- ============================================================
-- 共用：偵測 blast/aoe_blast 在 50 單位內並傳送到自己位置
-- ============================================================
local function pullNearbyBlast(hrp)
    pcall(function()
        local myPos = hrp.Position
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj.Name == "blast" or obj.Name == "aoe_blast" then
                local objPart
                if obj:IsA("BasePart") then
                    objPart = obj
                elseif obj:IsA("Model") and obj.PrimaryPart then
                    objPart = obj.PrimaryPart
                end
                if objPart and (objPart.Position - myPos).Magnitude <= 50 then
                    objPart.CFrame = CFrame.new(myPos)
                    break
                end
            end
        end
    end)
end

-- ============================================================
-- 幫助者位置迴圈：被打後不重置
-- ============================================================
local function runHelpLoopNoReset(hrp, hum, tgt)
    while toggles.helpTarget do
        if not (hrp and hrp.Parent) then break end
        if hum.Health <= 0 then break end

        pcall(function()
            if toggles.fixedPosHelp and values.fixedCFrame then
                hrp.CFrame = values.fixedCFrame
            elseif not toggles.fixedPosHelp then
                local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                if tgtRoot then
                    local lookDir = tgtRoot.CFrame.LookVector
                    local newPos = tgtRoot.Position + (lookDir * values.helpDistance)
                    hrp.CFrame = CFrame.new(newPos, newPos + lookDir)
                end
            end
        end)

        -- 偵測並拉近 blast
        pullNearbyBlast(hrp)

        task.wait()
    end
end

-- ============================================================
-- 幫助者位置迴圈：被blast時重置
-- ragdoll 時，若 aoe_blast 在自己 30 單位內 且 自己在攻擊者 15 單位內 → 等 0.5s 後重置
-- 其他情況 ragdoll → 等自然結束，不干涉
-- ============================================================
local function runHelpLoopRagdollReset(hrp, hum, tgt)

    -- 檢查是否有 aoe_blast 在自己 30 單位內
    local function aoeBlastNearby()
        local result = false
        pcall(function()
            local myPos = hrp.Position
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if obj.Name == "aoe_blast" then
                    local objPos
                    if obj:IsA("BasePart") then
                        objPos = obj.Position
                    elseif obj:IsA("Model") and obj.PrimaryPart then
                        objPos = obj.PrimaryPart.Position
                    end
                    if objPos and (objPos - myPos).Magnitude <= 30 then
                        result = true
                        break
                    end
                end
            end
        end)
        return result
    end

    -- 檢查自己是否在攻擊者（tgt）15 單位內
    local function nearAttacker()
        local result = false
        pcall(function()
            local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
            if tgtRoot then
                result = (tgtRoot.Position - hrp.Position).Magnitude <= 15
            end
        end)
        return result
    end

    while toggles.helpTarget do
        if not (hrp and hrp.Parent) then break end
        if hum.Health <= 0 then break end

        -- ragdoll 和非 ragdoll 都固定/跟隨位置
        pcall(function()
            if toggles.fixedPosHelp and values.fixedCFrame then
                hrp.CFrame = values.fixedCFrame
            elseif not toggles.fixedPosHelp then
                local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                if tgtRoot then
                    local lookDir = tgtRoot.CFrame.LookVector
                    local newPos = tgtRoot.Position + (lookDir * values.helpDistance)
                    hrp.CFrame = CFrame.new(newPos, newPos + lookDir)
                end
            end
        end)

        -- 偵測並拉近 blast
        pullNearbyBlast(hrp)

        -- ragdoll 中：判斷是否需要重置
        if isSelfRagdoll() then
            if aoeBlastNearby() and nearAttacker() then
                -- 條件成立，等 0.5 秒後 Reset
                task.wait(0.5)
                if not toggles.helpTarget then break end
                pcall(function()
                    Players.LocalPlayer.Reset:FireServer()
                end)
                -- 等重生（hrp 和 hum 會失效，外層迴圈會 break，由主流程重新啟動）
                task.wait(0.1)
                break
            end
        end

        task.wait(0.05)
    end
end

