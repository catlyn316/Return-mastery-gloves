helpTargetButton.MouseButton1Click:Connect(function()
    toggles.helpTarget = not toggles.helpTarget

    if toggles.helpTarget then
        local targetPlayer, errorMsg = findPlayerByPartialName(helpTargetInput.Text)

        if not targetPlayer then
            helpTargetInfo.Text = errorMsg or "找不到玩家"
            helpTargetInfo.TextColor3 = Color3.fromRGB(200, 0, 0)
            toggles.helpTarget = false
            return
        end

        values.targetPlayer = targetPlayer
        helpTargetInfo.Text = "目標: " .. targetPlayer.Name
        helpTargetInfo.TextColor3 = THEME.accent

        connections.helpTarget = task.spawn(function()

            local function waitForAliveCharacter(timeout)
                local t = tick()
                while tick() - t < (timeout or 15) do
                    if not toggles.helpTarget then return nil, nil, nil end
                    local c = player.Character
                    if c then
                        local hrp = c:FindFirstChild("HumanoidRootPart")
                        local hum = c:FindFirstChildOfClass("Humanoid")
                        if hrp and hum and hum.Health > 0 then
                            return c, hrp, hum
                        end
                    end
                    task.wait(0.2)
                end
                return nil, nil, nil
            end

            local function teleportToLobby(hrp)
                pcall(function()
                    local tp1 = Workspace.Lobby:FindFirstChild("Teleport1")
                    if tp1 and hrp and hrp.Parent then
                        hrp.CFrame = tp1.CFrame
                    end
                end)
            end

            local function teleportToTarget(hrp, tgt)
                pcall(function()
                    if not (hrp and hrp.Parent) then return end
                    local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                    if tgtRoot then
                        local lookDir = tgtRoot.CFrame.LookVector
                        local newPos = tgtRoot.Position + (lookDir * values.helpDistance)
                        local newCFrame = CFrame.new(newPos, newPos + lookDir)
                        hrp.CFrame = newCFrame
                        values.fixedCFrame = newCFrame
                    end
                end)
            end

            while toggles.helpTarget do
                local tgt = values.targetPlayer

                local _, hrp, hum = waitForAliveCharacter(15)
                if not hrp then task.wait(0.5) continue end
                if not toggles.helpTarget then break end

                teleportToLobby(hrp)
                task.wait(0.5)
                if not toggles.helpTarget then break end

                -- 傳送到目標，若5秒內沒成功則重新開始流程
                local teleportSuccess = false
                local tpStart = tick()
                while toggles.helpTarget and tick() - tpStart < 5 do
                    teleportToTarget(hrp, tgt)
                    -- 檢查是否已到目標附近（5單位內視為成功）
                    pcall(function()
                        local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                        if tgtRoot and hrp and hrp.Parent then
                            if (tgtRoot.Position - hrp.Position).Magnitude <= (values.helpDistance + 5) then
                                teleportSuccess = true
                            end
                        end
                    end)
                    if teleportSuccess then break end
                    task.wait(0.5)
                end
                if not toggles.helpTarget then break end
                if not teleportSuccess then continue end  -- 5秒沒傳成功，重新開始

                if values.helpMode == "被打後不重置" then
                    runHelpLoopNoReset(hrp, hum, tgt)
                else
                    runHelpLoopRagdollReset(hrp, hum, tgt)
                end
            end
        end)

        toggleUIState(helpTargetButton, helpTargetFrame, nil, true)
        helpTargetButton.Text = "解除"
        helpTargetButton.BackgroundColor3 = THEME.red
    else
        helpTargetInfo.Text = "目標: 無"
        helpTargetInfo.TextColor3 = THEME.textMuted
        values.targetPlayer = nil

        if connections.helpTarget then
            task.cancel(connections.helpTarget)
            connections.helpTarget = nil
        end

        helpTargetButton.Text = "啟動"
        helpTargetButton.BackgroundColor3 = THEME.primary
    end
    updateStatus()
end)

