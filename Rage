-- ============================================================
-- 共用：偵測 blast 在 50 單位內，持續把 blast 下所有部件傳到自己位置直到消失
-- ============================================================
local activeBlastLoops = {}

local function pullNearbyBlast(hrp)
    pcall(function()
        local myPos = hrp.Position
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj.Name == "blast" and not activeBlastLoops[obj] then
                local refPart
                if obj:IsA("BasePart") then
                    refPart = obj
                elseif obj:IsA("Model") and obj.PrimaryPart then
                    refPart = obj.PrimaryPart
                end
                if refPart and (refPart.Position - myPos).Magnitude <= 50 then
                    activeBlastLoops[obj] = true
                    task.spawn(function()
                        while obj and obj.Parent and hrp and hrp.Parent and toggles.helpTarget do
                            local target = hrp.Position
                            pcall(function()
                                if obj:IsA("BasePart") then
                                    obj.CFrame = CFrame.new(target)
                                elseif obj:IsA("Model") then
                                    for _, part in ipairs(obj:GetDescendants()) do
                                        if part:IsA("BasePart") then
                                            part.CFrame = CFrame.new(target)
                                        end
                                    end
                                end
                            end)
                            task.wait()
                        end
                        activeBlastLoops[obj] = nil
                    end)
                end
            end
        end
    end)
end

