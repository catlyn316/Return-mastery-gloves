-- ============================================================
-- 攻擊者主邏輯
-- 階段A（rage 從 0 爬到 100）：每 attackInterval 秒打一次
-- 階段B（rage == 100）：發動 frenzy，進入 frenzy 循環
-- 階段C（frenzy 中）：
--   rage <= minRage 且 20 單位內有人 → 打一次，等 rage 回到 minRage 以上
--   rage == 0（降過頭）→ 每 attackInterval 秒打直到 rage 回到 minRage
--   rage 回到 0 後再爬到 100 → 重新發動 frenzy
-- ============================================================
local function hasTargetNearby()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end
    local myPos = char.HumanoidRootPart.Position
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            if (p.Character.HumanoidRootPart.Position - myPos).Magnitude <= 20 then
                return true
            end
        end
    end
    return false
end

local function runAttackerLoop()
    local frenzyActive = false

    -- 自己怒氣值趨勢偵測（階段C用）
    local rageSamples = {}
    local RAGE_WINDOW = 5
    local rageTimer = 0

    local function pushRageSample(r)
        table.insert(rageSamples, r)
        if #rageSamples > RAGE_WINDOW then table.remove(rageSamples, 1) end
    end

    local function selfRageHasAnyDrop()
        for i = 2, #rageSamples do
            if rageSamples[i] < rageSamples[i-1] then return true end
        end
        return false
    end

    while toggles.attacker do
        local char = player.Character
        if not char then task.wait(0.2) continue end

        local rage = getSelfAttr("rage_percent") or 0

        if not frenzyActive then
            -- 【階段A】rage 從 0 爬到 100，每 attackInterval 秒攻擊一次
            rageSamples = {}  -- 重置取樣
            if rage < 100 then
                local leftArm = getNearestTargetLeftArm()
                if leftArm then
                    pcall(function() ReplicatedStorage.GRRRR:FireServer(leftArm) end)
                end
                task.wait(values.attackInterval)
            else
                -- rage 到 100，發動 frenzy
                pcall(function() ReplicatedStorage.GRRRRR:FireServer("frenzy") end)
                frenzyActive = true
                -- 等 rage 開始下降
                local timeout = tick() + 10
                while toggles.attacker and tick() < timeout do
                    local c = player.Character
                    local r = (c and c:GetAttribute("rage_percent")) or 0
                    if r < 100 then break end
                    task.wait(0.05)
                end
            end

        else
            -- 【階段C】frenzy 中
            -- 每 0.1s 取樣自己怒氣值，偵測趨勢
            rageTimer = rageTimer + 0.05
            if rageTimer >= 0.1 then
                rageTimer = 0
                pushRageSample(rage)

                -- 若樣本夠且不再下降（全部上升或持平）→ 視為遊戲已切回階段A
                if #rageSamples >= RAGE_WINDOW and not selfRageHasAnyDrop() then
                    frenzyActive = false
                    rageSamples = {}
                    task.wait(0.05)
                    continue
                end
            end

            if rage <= values.minRage and rage > 0 then
                if hasTargetNearby() then
                    local leftArm = getNearestTargetLeftArm()
                    if leftArm then
                        pcall(function() ReplicatedStorage.GRRRR:FireServer(leftArm) end)
                    end
                end
                task.wait(values.attackInterval)

                -- 攻擊後若 rage 回到 minRage 以上，等它再次降下來
                local c = player.Character
                local r = (c and c:GetAttribute("rage_percent")) or 0
                if r > values.minRage then
                    while toggles.attacker do
                        local c2 = player.Character
                        local r2 = (c2 and c2:GetAttribute("rage_percent")) or 0
                        if r2 <= values.minRage then break end
                        task.wait(0.05)
                    end
                end

            else
                -- rage > minRage，等
                task.wait(0.05)
            end
        end
    end
end

