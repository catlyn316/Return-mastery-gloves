local function findPlayerByPartialName(input)
    if not input or input == "" then return nil, "請輸入玩家名稱" end
    input = input:lower()
    local matches = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            if p.Name:lower():sub(1, #input) == input or p.DisplayName:lower():sub(1, #input) == input then
                table.insert(matches, p)
            end
        end
    end
    if #matches == 0 then return nil, "找不到玩家"
    elseif #matches == 1 then return matches[1], nil
    else
        local names = {}
        for _, p in ipairs(matches) do table.insert(names, p.Name) end
        return nil, "找到多個玩家: " .. table.concat(names, ", ") .. "\n請輸入更多字元"
    end
end

-- 取得距離最近的目標（幫助者）的 Left Arm
local function getNearestTargetLeftArm()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = char.HumanoidRootPart.Position
    local nearest, minDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Left Arm") then
            local d = (p.Character.HumanoidRootPart.Position - myPos).Magnitude
            if d < minDist then
                minDist = d
                nearest = p
            end
        end
    end
    return nearest and nearest.Character and nearest.Character:FindFirstChild("Left Arm") or nil
end

-- 讀取自己角色 Attributes
local function getSelfAttr(name)
    local char = player.Character
    if not char then return nil end
    local ok, val = pcall(function() return char:GetAttribute(name) end)
    return ok and val or nil
end

-- 讀取某玩家角色 Attributes
local function getPlayerAttr(p, name)
    if not p or not p.Character then return nil end
    local ok, val = pcall(function() return p.Character:GetAttribute(name) end)
    return ok and val or nil
end

-- 判斷某玩家角色是否處於 ragdoll
local function isPlayerRagdoll(targetPlayer)
    local result = false
    pcall(function()
        local folder = Workspace:FindFirstChild(targetPlayer.Name)
        if folder then
            local r = folder:FindFirstChild("Ragdolled")
            if r then result = r.Value == true end
        end
    end)
    return result
end

-- 判斷自己是否 ragdoll
local function isSelfRagdoll()
    return isPlayerRagdoll(player)
end

-- 讀取 Workspace.玩家名.LastSlappedBy
local function getSelfLastSlappedBy()
    local result = nil
    pcall(function()
        local folder = Workspace:FindFirstChild(player.Name)
        if folder then
            local obj = folder:FindFirstChild("LastSlappedBy")
            if obj then result = obj.Value end
        end
    end)
    return result
end

