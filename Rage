-- ============================================================
-- 幫助者位置迴圈：被打時重置
--
-- 偵測方式：監聽 Workspace.自己名.Ragdolled 從 false→true
-- （被攻擊者打到會進入 ragdoll，這個值每次都真的改變）
-- 再確認 LastSlappedBy == tgt.Name 才執行重置
--
-- 階段判斷（每 0.1s 取樣一次，保留最近 5 筆）：
--   5 筆中只要有任何一次「當前值 < 前一值」→ 下降階段（可重置）
--   5 筆全部上升或持平 → 上升階段（不可重置）
--   偵測到 rage >= 100 → 強制下降階段
--   偵測到 rage == 0  → 強制上升階段
-- ============================================================
local function runHelpLoopSlappedReset(hrp, hum, tgt)

    -- 取得自己的 Ragdolled 物件
    local ragdolledObj = nil
    pcall(function()
        local folder = Workspace:FindFirstChild(player.Name)
        if folder then
            ragdolledObj = folder:FindFirstChild("Ragdolled")
        end
    end)
    print("[診斷] Ragdolled 物件:", ragdolledObj and "找到 ✅" or "找不到 ❌")
    print("[診斷] 幫助目標名稱:", tgt.Name)

    -- 初始階段
    local initRage = getPlayerAttr(tgt, "rage_percent") or 0
    local tgtRageDescending = (initRage > 0)
    print("[診斷] 初始怒氣值:", initRage, "| 初始階段:", tgtRageDescending and "下降(可重置)" or "上升(不可重置)")

    -- 取樣視窗
    local WINDOW = 5
    local samples = {}
    local sampleTimer = 0

    local function pushSample(r)
        table.insert(samples, r)
        if #samples > WINDOW then table.remove(samples, 1) end
    end

    local function hasAnyDrop()
        for i = 2, #samples do
            if samples[i] < samples[i-1] then return true end
        end
        return false
    end

    pushSample(initRage)

    -- 用 Ragdolled.Changed 偵測被打
    local gotHit = false
    local ragdolledConn = nil

    local function setupRagdolledConn()
        if ragdolledConn then pcall(function() ragdolledConn:Disconnect() end) end
        if not ragdolledObj or not ragdolledObj.Parent then
            print("[診斷] setupRagdolledConn: 物件無效，跳過綁定 ❌")
            return
        end
        ragdolledConn = ragdolledObj.Changed:Connect(function(newVal)
            print("[診斷] Ragdolled Changed 觸發! 新值:", newVal, "| 當前階段:", tgtRageDescending and "下降(可重置)" or "上升(不可重置)")
            if newVal == true then
                -- 被打後 LastSlappedBy 才會存在，在這裡即時讀取
                local slappedBy = ""
                pcall(function()
                    local folder = Workspace:FindFirstChild(player.Name)
                    if folder then
                        local obj = folder:FindFirstChild("LastSlappedBy")
                        if obj then slappedBy = tostring(obj.Value) or "" end
                    end
                end)
                print("[診斷] LastSlappedBy 當前值:", slappedBy, "| 目標名:", tgt.Name, "| 符合:", slappedBy == tgt.Name)
                if slappedBy == tgt.Name then
                    gotHit = true
                    print("[診斷] gotHit 設為 true ✅")
                end
            end
        end)
        print("[診斷] Ragdolled.Changed 綁定成功 ✅")
    end

    setupRagdolledConn()

    while toggles.helpTarget do
        if not (hrp and hrp.Parent) then break end
        if hum.Health <= 0 then break end

        -- 若 Ragdolled 物件失效，重新取得並重新綁定
        if not ragdolledObj or not ragdolledObj.Parent then
            print("[診斷] Ragdolled 物件失效，重新取得...")
            pcall(function()
                local folder = Workspace:FindFirstChild(player.Name)
                if folder then
                    ragdolledObj = folder:FindFirstChild("Ragdolled")
                end
            end)
            setupRagdolledConn()
        end

        -- 固定位置
        pcall(function()
            if toggles.fixedPosHelp and values.fixedCFrame then
                hrp.CFrame = values.fixedCFrame
            elseif not toggles.fixedPosHelp then
                local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                if tgtRoot then
                    local lookDir = tgtRoot.CFrame.LookVector
                    local newPos = tgtRoot.Position + (lookDir * values.helpDistance)
                    hrp.CFrame = CFrame.new(newPos, newPos + lookDir)
                end
            end
        end)

        pullNearbyBlast(hrp)

        -- 每 0.1s 取樣並更新階段
        sampleTimer = sampleTimer + 0.05
        if sampleTimer >= 0.1 then
            sampleTimer = 0
            local tgtRage = getPlayerAttr(tgt, "rage_percent") or 0
            pushSample(tgtRage)

            local prevState = tgtRageDescending
            if tgtRage >= 100 then
                tgtRageDescending = true
            elseif tgtRage == 0 then
                tgtRageDescending = false
            elseif #samples >= 3 then
                tgtRageDescending = hasAnyDrop()
            end

            -- 階段有變化時才印
            if tgtRageDescending ~= prevState then
                print("[診斷] 階段切換! 怒氣:", tgtRage, "| 現在:", tgtRageDescending and "下降(可重置)" or "上升(不可重置)", "| 樣本:", table.concat(samples, ","))
            end
        end

        -- 被幫助目標打到了
        if gotHit then
            gotHit = false
            print("[診斷] gotHit 處理中 | tgtRageDescending:", tgtRageDescending)

            if tgtRageDescending then
                print("[診斷] 條件成立，執行重置! ✅")
                if ragdolledConn then pcall(function() ragdolledConn:Disconnect() end) end
                pcall(function()
                    Players.LocalPlayer.Reset:FireServer()
                end)
                task.wait(0.1)
                break
            else
                print("[診斷] 上升階段，忽略重置 ❌")
            end
        end

        task.wait(0.05)
    end

    -- 清理連線
    if ragdolledConn then pcall(function() ragdolledConn:Disconnect() end) end
end

