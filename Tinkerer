-- 內部解除自動使用能力的函數（供監聽器呼叫）
local function disableAutoAbility()
    if not toggles.autoAbility then return end
    toggles.autoAbility = false
    autoAbilityStatus.Text = "關閉"
    autoAbilityStatus.TextColor3 = THEME.textMuted
    if connections.autoAbility then
        connections.autoAbility:Disconnect()
        connections.autoAbility = nil
    end
    toggleUIState(autoAbilityButton, autoAbilityFrame, autoAbilityStatus, false)
end

-- 監聽角色工具狀態與死亡的連線表
local abilityWatchConnections = {}

local function setupAbilityWatchers()
    -- 清除舊的監聽
    for _, c in pairs(abilityWatchConnections) do
        if c then pcall(function() c:Disconnect() end) end
    end
    abilityWatchConnections = {}

    local char = player.Character
    if not char then return end

    -- 偵測死亡
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        abilityWatchConnections.died = hum.Died:Connect(function()
            disableAutoAbility()
        end)
    end

    -- 偵測工具 unequip（BackpackItem 回到 Backpack）
    -- Roblox 的 Tool 在裝備時為 Character 的子物件，unequip 後移回 Backpack
    -- 用 ChildRemoved 監聽 Character 中的 Tool 離開
    abilityWatchConnections.toolRemoved = char.ChildRemoved:Connect(function(child)
        if child:IsA("Tool") then
            disableAutoAbility()
        end
    end)
end

autoAbilityButton.MouseButton1Click:Connect(function()
    toggles.autoAbility = not toggles.autoAbility

    if toggles.autoAbility then
        autoAbilityStatus.Text = "運行中"
        autoAbilityStatus.TextColor3 = THEME.primaryDark

        -- 設置 unequip / 死亡監聽
        setupAbilityWatchers()

        local lastAbilityTime = 0

        connections.autoAbility = RunService.Heartbeat:Connect(function()
            local now = tick()
            if (now - lastAbilityTime) < values.abilityInterval then return end
            lastAbilityTime = now
            pcall(function()
                ReplicatedStorage.GeneralAbility:FireServer("E_ABILITY")
            end)
        end)
    else
        autoAbilityStatus.Text = "關閉"
        autoAbilityStatus.TextColor3 = THEME.textMuted
        if connections.autoAbility then
            connections.autoAbility:Disconnect()
            connections.autoAbility = nil
        end
        -- 清除監聽
        for _, c in pairs(abilityWatchConnections) do
            if c then pcall(function() c:Disconnect() end) end
        end
        abilityWatchConnections = {}
    end

    toggleUIState(autoAbilityButton, autoAbilityFrame, autoAbilityStatus, toggles.autoAbility)
end)

