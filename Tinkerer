-- ============================================================
helpTargetButton.MouseButton1Click:Connect(function()
    toggles.helpTarget = not toggles.helpTarget

    if toggles.helpTarget then
        local targetPlayer, errorMsg = findPlayerByPartialName(helpTargetInput.Text)

        if not targetPlayer then
            helpTargetInfo.Text = errorMsg or "找不到玩家"
            helpTargetInfo.TextColor3 = Color3.fromRGB(200, 0, 0)
            toggles.helpTarget = false
            return
        end

        values.targetPlayer = targetPlayer
        helpTargetInfo.Text = "目標: " .. targetPlayer.Name
        helpTargetInfo.TextColor3 = THEME.primaryDark

        connections.helpTarget = task.spawn(function()

            local alreadyPositioned = false

            while toggles.helpTarget do
                if alreadyPositioned then
                    task.wait(0.5)
                    continue
                end

                local character = player.Character
                if not character then
                    character = player.CharacterAdded:Wait()
                end

                local humanoidRootPart = character:WaitForChild("HumanoidRootPart", 10)
                local humanoid = character:WaitForChild("Humanoid", 10)

                if not humanoidRootPart or not humanoid then
                    task.wait(0.5)
                    continue
                end

                if humanoid.Health <= 0 then
                    task.wait(0.3)
                    continue
                end

                pcall(function()
                    -- 先傳送到 Teleport1
                    local teleport1 = Workspace.Lobby:FindFirstChild("Teleport1")
                    if teleport1 and toggles.helpTarget then
                        humanoidRootPart.CFrame = teleport1.CFrame
                        task.wait(0.5)
                    end

                    local tgtPlayer = values.targetPlayer
                    if not (tgtPlayer and tgtPlayer.Character and tgtPlayer.Character:FindFirstChild("HumanoidRootPart")) then
                        return
                    end

                    if not toggles.helpTarget then return end

                    if values.helpMode == "ragdoll時傳虛空" then
                        -- --------------------------------------------------------
                        -- ragdoll時傳虛空模式：
                        -- 1. 初始定位到目標前方
                        -- 2. 監測 ragdoll 狀態
                        -- 3. 一旦進入 ragdoll → 把自己 Y 座標改為 -85（掉虛空死亡）
                        -- 4. 等死亡後重生，等 0.5 秒 → 傳 Teleport1 → 等 0.5 秒 → 傳目標前方
                        -- --------------------------------------------------------

                        -- 初始定位
                        pcall(function()
                            local targetRoot = tgtPlayer.Character.HumanoidRootPart
                            local lookDir = targetRoot.CFrame.LookVector
                            local newPos = targetRoot.Position + (lookDir * values.helpDistance)
                            local newCFrame = CFrame.new(newPos, newPos + lookDir)
                            humanoidRootPart.CFrame = newCFrame
                            if toggles.fixedPosition then
                                values.fixedCFrame = newCFrame
                            end
                        end)

                        -- 固定/跟隨 + ragdoll 偵測迴圈
                        local ragdollDetected = false
                        while toggles.helpTarget and not ragdollDetected do
                            pcall(function()
                                if not (humanoidRootPart and humanoidRootPart.Parent) then return end

                                local state = humanoid:GetState()
                                local isRagdoll = (state == Enum.HumanoidStateType.Ragdoll or
                                                   state == Enum.HumanoidStateType.FallingDown or
                                                   state == Enum.HumanoidStateType.Physics)

                                if isRagdoll then
                                    -- 觸發虛空傳送
                                    ragdollDetected = true
                                    local currentPos = humanoidRootPart.Position
                                    humanoidRootPart.CFrame = CFrame.new(currentPos.X, -85, currentPos.Z)
                                    return
                                end

                                -- 正常固定或跟隨
                                if toggles.fixedPosition and values.fixedCFrame then
                                    humanoidRootPart.CFrame = values.fixedCFrame
                                elseif not toggles.fixedPosition then
                                    local targetRoot = tgtPlayer.Character and tgtPlayer.Character:FindFirstChild("HumanoidRootPart")
                                    if targetRoot then
                                        local lookDir = targetRoot.CFrame.LookVector
                                        local newPos = targetRoot.Position + (lookDir * values.helpDistance)
                                        humanoidRootPart.CFrame = CFrame.new(newPos, newPos + lookDir)
                                    end
                                end
                            end)
                            task.wait(0.1)
                        end

                        if ragdollDetected and toggles.helpTarget then
                            -- 等待死亡
                            local t0 = tick()
                            repeat task.wait(0.2)
                            until not player.Character or
                                  (player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health <= 0)
                                  or tick()-t0 > 5

                            -- 等待新角色重生
                            local newCharacter = nil
                            local t1 = tick()
                            repeat
                                task.wait(0.2)
                                newCharacter = player.Character
                            until (newCharacter and newCharacter:FindFirstChild("HumanoidRootPart") and
                                  newCharacter:FindFirstChild("Humanoid") and newCharacter.Humanoid.Health > 0)
                                  or tick()-t1 > 10

                            if not toggles.helpTarget then return end

                            -- 重生後等 0.5 秒
                            task.wait(0.5)

                            if not toggles.helpTarget then return end

                            -- 傳送到 Teleport1
                            pcall(function()
                                local newHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                                local tp1 = Workspace.Lobby:FindFirstChild("Teleport1")
                                if newHRP and tp1 then
                                    newHRP.CFrame = tp1.CFrame
                                end
                            end)

                            -- 等 0.5 秒
                            task.wait(0.5)

                            if not toggles.helpTarget then return end

                            -- 傳送到目標前方
                            pcall(function()
                                local newHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                                if not newHRP then return end
                                local tgt = values.targetPlayer
                                if tgt and tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart") then
                                    local targetRoot = tgt.Character.HumanoidRootPart
                                    local lookDir = targetRoot.CFrame.LookVector
                                    local newPos = targetRoot.Position + (lookDir * values.helpDistance)
                                    local newCFrame = CFrame.new(newPos, newPos + lookDir)
                                    newHRP.CFrame = newCFrame
                                    values.fixedCFrame = newCFrame
                                end
                            end)

                            -- alreadyPositioned 保持 false，讓外層 while 重新迭代（但下次直接跳過 Teleport1，因為剛傳過了）
                            -- 實際上外層會再跑一次，但我們已手動完成所有步驟
                            -- 設定 alreadyPositioned = true，防止外層再次傳 Teleport1
                            alreadyPositioned = true

                            -- 進入固定/跟隨的永久迴圈（新角色）
                            local newChar = player.Character
                            if not newChar then return end
                            local newHRP = newChar:FindFirstChild("HumanoidRootPart")
                            local newHum = newChar:FindFirstChild("Humanoid")
                            if not newHRP or not newHum then return end

                            -- 重新進入 ragdoll 偵測迴圈
                            local ragdollDetected2 = false
                            while toggles.helpTarget and not ragdollDetected2 do
                                pcall(function()
                                    if not (newHRP and newHRP.Parent) then return end
                                    local state = newHum:GetState()
                                    local isRagdoll = (state == Enum.HumanoidStateType.Ragdoll or
                                                       state == Enum.HumanoidStateType.FallingDown or
                                                       state == Enum.HumanoidStateType.Physics)

                                    if isRagdoll then
                                        ragdollDetected2 = true
                                        local currentPos = newHRP.Position
                                        newHRP.CFrame = CFrame.new(currentPos.X, -85, currentPos.Z)
                                        return
                                    end

                                    if toggles.fixedPosition and values.fixedCFrame then
                                        newHRP.CFrame = values.fixedCFrame
                                    elseif not toggles.fixedPosition then
                                        local tgt = values.targetPlayer
                                        local targetRoot = tgt and tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                                        if targetRoot then
                                            local lookDir = targetRoot.CFrame.LookVector
                                            local newPos = targetRoot.Position + (lookDir * values.helpDistance)
                                            newHRP.CFrame = CFrame.new(newPos, newPos + lookDir)
                                        end
                                    end
                                end)
                                task.wait(0.1)
                            end

                            -- 若再次 ragdoll，重置 alreadyPositioned 讓外層重新走完整流程
                            if ragdollDetected2 then
                                alreadyPositioned = false
                            end
                        end

                    else
                        -- --------------------------------------------------------
                        -- 被打後不重置模式（原始行為）
                        -- --------------------------------------------------------

                        pcall(function()
                            local targetRoot = tgtPlayer.Character.HumanoidRootPart
                            local lookDir = targetRoot.CFrame.LookVector
                            local newPos = targetRoot.Position + (lookDir * values.helpDistance)
                            local newCFrame = CFrame.new(newPos, newPos + lookDir)
                            humanoidRootPart.CFrame = newCFrame
                            values.fixedCFrame = newCFrame
                        end)

                        alreadyPositioned = true

                        while toggles.helpTarget do
                            pcall(function()
                                if not (humanoidRootPart and humanoidRootPart.Parent) then return end

                                local state = humanoid:GetState()
                                local isRagdoll = (state == Enum.HumanoidStateType.Ragdoll or
                                                   state == Enum.HumanoidStateType.FallingDown or
                                                   state == Enum.HumanoidStateType.Physics)

                                if toggles.fixedPosition then
                                    if not isRagdoll and values.fixedCFrame then
                                        humanoidRootPart.CFrame = values.fixedCFrame
                                    end
                                else
                                    local targetRoot = tgtPlayer.Character and tgtPlayer.Character:FindFirstChild("HumanoidRootPart")
                                    if targetRoot then
                                        local lookDir = targetRoot.CFrame.LookVector
                                        local newPos = targetRoot.Position + (lookDir * values.helpDistance)
                                        humanoidRootPart.CFrame = CFrame.new(newPos, newPos + lookDir)
                                    end
                                end
                            end)
                            task.wait(0.1)
                        end
                    end
                end)

                if toggles.helpTarget and not alreadyPositioned then
                    task.wait(0.5)
                end
            end
        end)
    else
        helpTargetInfo.Text = "目標: 無"
        helpTargetInfo.TextColor3 = THEME.textMuted
        values.targetPlayer = nil

        if connections.helpTarget then
            task.cancel(connections.helpTarget)
            connections.helpTarget = nil
        end
    end

    toggleUIState(helpTargetButton, helpTargetFrame, helpTargetInput, toggles.helpTarget)
end)

