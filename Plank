-- ============================================================
-- 攻擊者主邏輯
-- 跳躍 loop（持續不停跳）與攻擊 loop 分開並行
-- 支援電腦（keypress空白鍵）與平板（模擬觸控跳躍按鈕）
-- ============================================================

-- 嘗試取得平板跳躍按鈕（TouchJump）
local function getTouchJumpButton()
    local PlayerGui = player:FindFirstChild("PlayerGui")
    if not PlayerGui then return nil end
    local touchGui = PlayerGui:FindFirstChild("TouchGui")
    if not touchGui then return nil end
    local touchControlFrame = touchGui:FindFirstChild("TouchControlFrame")
    if not touchControlFrame then return nil end
    return touchControlFrame:FindFirstChild("JumpButton")
end

local function doJump()
    -- 方法1：平板觸控跳躍按鈕模擬
    local jumpBtn = getTouchJumpButton()
    if jumpBtn then
        pcall(function()
            local pos = jumpBtn.AbsolutePosition + jumpBtn.AbsoluteSize / 2
            VirtualUser:TouchStart({pos}, CFrame.new())
            task.wait(0.05)
            VirtualUser:TouchEnd({pos}, CFrame.new())
        end)
        return
    end
    -- 方法2：電腦鍵盤空白鍵
    pcall(function()
        if type(keypress) == "function" then
            keypress(0x20)
            task.wait(0.05)
            keyrelease(0x20)
        end
    end)
end

-- 持續跳躍 loop（落地後馬上再跳）
local function runJumpLoop()
    while toggles.attacker do
        local char = player.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum then
            local state = hum:GetState()
            -- 只在地面狀態才跳，避免觸發防無限跳偵測
            if state == Enum.HumanoidStateType.Running
            or state == Enum.HumanoidStateType.RunningNoPhysics
            or state == Enum.HumanoidStateType.Landed
            or state == Enum.HumanoidStateType.None then
                doJump()
            end
        end
        task.wait(0.3)
    end
end

-- 攻擊 loop
local function runAttackerLoop()
    -- 跳躍 loop 並行
    task.spawn(runJumpLoop)

    while toggles.attacker do
        local char = player.Character
        if not char then task.wait(0.2) continue end

        local torso = getNearestTargetTorso()
        if torso then
            pcall(function() ReplicatedStorage.GeneralHit:FireServer(torso) end)
        end

        task.wait(values.attackInterval)
    end
end

attackerButton.MouseButton1Click:Connect(function()
    toggles.attacker = not toggles.attacker
    if toggles.attacker then
        connections.attacker = task.spawn(runAttackerLoop)
    else
        if connections.attacker then task.cancel(connections.attacker) connections.attacker = nil end
    end
    toggleUIState(attackerButton, attackerFrame, attackerStatus, toggles.attacker, "運行中", "關閉")
end)

-- ============================================================
-- 自動能力
-- 每 0.5 秒：面向最近玩家 → GeneralAbility:FireServer(CFrame, Vector3)
-- ============================================================
local function runAutoAbilityLoop()
    while toggles.autoAbility do
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")

        if hrp then
            local nearest = getNearestTarget()
            if nearest and nearest.Character and nearest.Character:FindFirstChild("HumanoidRootPart") then
                -- 面向最近玩家
                local targetPos = nearest.Character.HumanoidRootPart.Position
                local lookCFrame = CFrame.new(hrp.Position, Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z))
                pcall(function() hrp.CFrame = lookCFrame end)
            end

            pcall(function()
                ReplicatedStorage.GeneralAbility:FireServer(
                    CFrame.new(-88.1749, 49.1773, 63.2741),
                    Vector3.new(114.5, 3, 0.35)
                )
            end)
        end

        task.wait(0.5)
    end
end

autoAbilityButton.MouseButton1Click:Connect(function()
    toggles.autoAbility = not toggles.autoAbility
    if toggles.autoAbility then
        connections.autoAbility = task.spawn(runAutoAbilityLoop)
