-- ============================================================
-- BubbleObject 偵測（被打後不重置模式專用）
-- 邏輯：
--   掃描場上所有名為 BubbleObject 的物件（可能同時多個）
--   對每個尚未處理的實例：
--     1. 在 200 單位內 → 觸發 TouchInterest，標記該實例為「碰到中」
--     2. 等待同一個實例從 Workspace 消失（Parent == nil）
--     3. 消失後才 +1，並檢查是否達上限
--   同一實例不重複觸發，消失前不計數
-- onReset: 計數達上限時回呼
-- ============================================================
local function startBubbleDetector(hrp, onReset)
    local running = true
    -- 記錄已在追蹤中的實例（用物件本身當 key）
    local tracked = {}   -- [bubbleObj] = true（正在等消失）

    local thread = task.spawn(function()
        while running and toggles.helpTarget do
            if hrp and hrp.Parent then
                local myPos = hrp.Position

                -- 掃描場上所有 BubbleObject
                for _, obj in ipairs(Workspace:GetChildren()) do
                    if obj.Name == "BubbleObject" and not tracked[obj] then
                        local hitbox = obj:FindFirstChild("Hitbox")
                        if hitbox and hitbox.Parent then
                            local dist = (hitbox.Position - myPos).Magnitude
                            if dist <= 200 then
                                -- 標記，避免重複處理同一實例
                                tracked[obj] = true

                                -- 觸發 TouchInterest
                                pcall(function()
                                    firetouchinterest(hrp, hitbox, 0)
                                end)

                                -- 非同步等待這個實例消失，消失後才 +1
                                local capturedObj = obj
                                task.spawn(function()
                                    -- 等待實例從場上移除
                                    while capturedObj and capturedObj.Parent ~= nil do
                                        task.wait(0.05)
                                    end

                                    -- 確認偵測器仍在執行才計數
                                    if not running then return end

                                    values.bubbleHitCount = values.bubbleHitCount + 1
                                    updateBubbleCountUI()
                                    tracked[capturedObj] = nil

                                    if values.bubbleHitCount >= values.bubbleHitLimit then
                                        running = false
                                        values.bubbleHitCount = 0
                                        updateBubbleCountUI()
                                        onReset()
                                    end
                                end)
                            end
                        end
                    end
                end
            end
            task.wait(0.1)
        end
    end)

    return function()
        running = false
        pcall(function() task.cancel(thread) end)
    end
end

-- ============================================================
-- 幫助者位置迴圈：被打後不重置
-- 含 BubbleObject 偵測，到 250 次自動重置
-- ============================================================
local function runHelpLoopNoReset(hrp, hum, tgt, onDone)
    local stopBubble = nil
    local resetTriggered = false

    stopBubble = startBubbleDetector(hrp, function()
        -- 計數到達上限，觸發重置
        resetTriggered = true
        pcall(function() Players.LocalPlayer.Reset:FireServer() end)
        task.wait(0.1)
        if stopBubble then stopBubble() end
        onDone()
    end)

    while toggles.helpTarget and not resetTriggered do
        if not (hrp and hrp.Parent) then break end
        if hum.Health <= 0 then break end

        pcall(function()
            if toggles.fixedPosHelp and values.fixedCFrame then
                hrp.CFrame = values.fixedCFrame
            elseif not toggles.fixedPosHelp then
                local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                if tgtRoot then
                    local lookDir = tgtRoot.CFrame.LookVector
                    local newPos = tgtRoot.Position + (lookDir * values.helpDistance)
                    hrp.CFrame = CFrame.new(newPos, newPos + lookDir)
                end
            end
        end)

        task.wait()
    end

    if stopBubble then stopBubble() end
    if not resetTriggered then onDone() end
end

-- ============================================================
-- 幫助者位置迴圈：被打時重置
-- 監聽 folder.ChildAdded 等 LastSlappedBy 出現，出現後立即讀值判斷
-- ============================================================
local function runHelpLoopSlappedReset(hrp, hum, tgt, onDone)
    local resetTriggered = false
    local folderConn     = nil

    local function setupFolderConn()
        if folderConn then pcall(function() folderConn:Disconnect() end) end
        pcall(function()
            local folder = Workspace:FindFirstChild(player.Name)
            if not folder then return end
            folderConn = folder.ChildAdded:Connect(function(child)
                if resetTriggered then return end
                if child.Name == "LastSlappedBy" then
                    local val = tostring(child.Value)
                    if val == tgt.Name then
                        resetTriggered = true
                        if folderConn then pcall(function() folderConn:Disconnect() end) end
                        pcall(function() Players.LocalPlayer.Reset:FireServer() end)
                        task.wait(0.1)
                        onDone()
                    end
                end
            end)
        end)
    end

    setupFolderConn()

    while toggles.helpTarget and not resetTriggered do
        if not (hrp and hrp.Parent) then break end
        if hum.Health <= 0 then break end

        -- folder 可能還不存在，持續嘗試綁定
        if not folderConn then
            setupFolderConn()
        end

        pcall(function()
            if toggles.fixedPosHelp and values.fixedCFrame then
                hrp.CFrame = values.fixedCFrame
            elseif not toggles.fixedPosHelp then
                local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                if tgtRoot then
                    local lookDir = tgtRoot.CFrame.LookVector
                    local newPos = tgtRoot.Position + (lookDir * values.helpDistance)
                    hrp.CFrame = CFrame.new(newPos, newPos + lookDir)
                end
            end
        end)

        task.wait(0.05)
    end

    if folderConn then pcall(function() folderConn:Disconnect() end) end
    if not resetTriggered then onDone() end
end

