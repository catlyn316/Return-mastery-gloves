-- ============================================================
-- 攻擊者：面向最近目標的持續 loop（攻擊者或能力任一開啟時執行）
-- 鎖定第一個偵測到的最近目標，之後不切換
-- ============================================================
local lockedTarget      = nil   -- 鎖定的目標（CFrame 用途）
local faceTargetLoop    = nil   -- loop thread
local faceTargetRunning = false

local function startFaceTargetLoop()
    if faceTargetRunning then return end
    faceTargetRunning = true
    -- 鎖定當前最近目標
    if not lockedTarget then
        lockedTarget = getNearestTarget()
    end
    faceTargetLoop = task.spawn(function()
        while faceTargetRunning do
            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp and lockedTarget and lockedTarget.Character and lockedTarget.Character:FindFirstChild("HumanoidRootPart") then
                local targetPos = lockedTarget.Character.HumanoidRootPart.Position
                local lookCFrame = CFrame.new(hrp.Position, Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z))
                pcall(function() hrp.CFrame = lookCFrame end)
            end
            task.wait(0.05)
        end
    end)
end

local function stopFaceTargetLoopIfNeeded()
    -- 只有在攻擊者和能力都關閉時才停止
    if not toggles.attacker and not toggles.autoAbility then
        faceTargetRunning = false
        if faceTargetLoop then task.cancel(faceTargetLoop) faceTargetLoop = nil end
        lockedTarget = nil
    end
end

-- ============================================================
-- 攻擊者主邏輯
-- 流程：BubbleHit → wait(attackInterval) → BubbleThrow → 重複
-- ============================================================
local function runAttackerLoop()
    while toggles.attacker do
        local char = player.Character
        if not char then task.wait(0.2) continue end

        local torso = getNearestTargetTorso()
        if torso then
            pcall(function() ReplicatedStorage.BubbleHit:FireServer(torso) end)
        end

        task.wait(values.attackInterval)

        if not toggles.attacker then break end

        pcall(function() ReplicatedStorage.BubbleThrow:FireServer() end)

        task.wait(0.1)
    end
end

attackerButton.MouseButton1Click:Connect(function()
    toggles.attacker = not toggles.attacker
    if toggles.attacker then
        lockedTarget = getNearestTarget()
        startFaceTargetLoop()
        connections.attacker = task.spawn(runAttackerLoop)
    else
        if connections.attacker then task.cancel(connections.attacker) connections.attacker = nil end
        stopFaceTargetLoopIfNeeded()
    end
    toggleUIState(attackerButton, attackerFrame, attackerStatus, toggles.attacker, "運行中", "關閉")
end)

-- ============================================================
-- 自動能力：每 abilityInterval 秒 BubbleThrow 一次
-- ============================================================
local function runAutoAbilityLoop()
    while toggles.autoAbility do
        pcall(function() ReplicatedStorage.BubbleThrow:FireServer() end)
        task.wait(values.abilityInterval)
    end
end

