    local roleMap = {
        main = "textMain", sub = "textSub", muted = "textMuted",
        accent = "accent", primary = "primary", green = "green",
    }
    for _, entry in ipairs(themedLabels) do
        local key = roleMap[entry.role]
        if key and THEME[key] then entry.label.TextColor3 = THEME[key] end
    end
end

