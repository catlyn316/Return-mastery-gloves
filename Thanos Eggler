local autoAtkRunning        = false
local autoAtkDetectedEvents = {}
local autoAtkPending        = false
local autoAtkHookSet        = false

local _auraNC
local function setupAutoAtkHook()
    if autoAtkHookSet then return end
    autoAtkHookSet = true
    _auraNC = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
        local method  = getnamecallmethod()
        local results = table.pack(_auraNC(self, ...))
        if autoAtkRunning and method == "FireServer" then
            local ok, cls = pcall(function() return self.ClassName end)
            if ok and cls == "RemoteEvent" then
                local args = {...}
                local isHit = false
                for _, v in ipairs(args) do
                    if typeof(v) == "Instance" then
                        if v:IsA("BasePart") then
                            for _, p in ipairs(Players:GetPlayers()) do
                                if p ~= player and p.Character == v.Parent then
                                    isHit = true; break
                                end
                            end
                        end
                        if v:IsA("Player") and v ~= player then isHit = true end
                        if v:IsA("Model") and v ~= player.Character and v:FindFirstChildOfClass("Humanoid") then
                            isHit = true
                        end
                    end
                    if isHit then break end
                end
                if isHit then
                    local found = false
                    for _, entry in ipairs(autoAtkDetectedEvents) do
                        if entry.event == self then entry.args = args; found = true; break end
                    end
                    if not found then
                        table.insert(autoAtkDetectedEvents, {event = self, args = args})
                    end
                    autoAtkPending = true
                end
            end
        end
        return table.unpack(results, 1, results.n)
    end))
end
pcall(setupAutoAtkHook)

RunService.Heartbeat:Connect(function()
    if not autoAtkRunning or not autoAtkPending then return end
    if #autoAtkDetectedEvents == 0 then autoAtkPending = false; return end
    autoAtkPending = false

    task.spawn(function()
        local target = getNearestPlayer()
        if not target then return end

        autoAtkStatusLabel.Text = "等 " .. target.Name .. " 起身…"
        autoAtkStatusLabel.TextColor3 = THEME.textMuted
        waitNotRagdoll(function()
            return Players:FindFirstChild(target.Name) and Players[target.Name].Character
        end, 6)

        if not autoAtkRunning then return end
        task.wait(0.8)
        if not autoAtkRunning then return end

        autoAtkStatusLabel.Text = "自動攻擊中！"
        autoAtkStatusLabel.TextColor3 = THEME.green

        target = getNearestPlayer()
        if not target or not target.Character then return end

        for _, entry in ipairs(autoAtkDetectedEvents) do
            local newArgs = {}
            local replaced = false
            for _, v in ipairs(entry.args) do
                local didReplace = false
                if typeof(v) == "Instance" and not replaced then
                    if v:IsA("BasePart") then
                        table.insert(newArgs, target.Character and target.Character:FindFirstChild(v.Name) or v)
                        didReplace = true; replaced = true
                    elseif v:IsA("Player") and v ~= player then
                        table.insert(newArgs, target); didReplace = true; replaced = true
                    elseif v:IsA("Model") and v:FindFirstChildOfClass("Humanoid") and v ~= player.Character then
                        table.insert(newArgs, target.Character or v); didReplace = true; replaced = true
                    end
                end
                if not didReplace then table.insert(newArgs, v) end
            end
            pcall(function() entry.event:FireServer(table.unpack(newArgs)) end)
        end

        if autoAtkRunning then
            autoAtkStatusLabel.Text = "等待下次事件…"
            autoAtkStatusLabel.TextColor3 = THEME.textMuted
        end
    end)
end)

