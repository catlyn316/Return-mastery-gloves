local function isRagdoll(character)
    if not character then return true end
    local hum = character:FindFirstChildOfClass("Humanoid")
    if not hum then return true end
    if hum.Health <= 0 then return true end
    local state = hum:GetState()
    if state == Enum.HumanoidStateType.FallingDown
    or state == Enum.HumanoidStateType.Ragdoll then return true end
    if character:FindFirstChild("Ragdoll") then return true end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if hrp and hrp.Anchored then return true end
    return false
end

local function isSelfRagdoll()
    return isRagdoll(player.Character)
end

local function getNearestPlayer()
    local char = player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local nearest, minDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
            if d < minDist then minDist = d; nearest = p end
        end
    end
    return nearest
end

local function getNearestEggVictim(maxDist)
    local char = player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    maxDist = maxDist or math.huge
    local nearest, minDist = nil, math.huge
    for _, obj in ipairs(Workspace:GetChildren()) do
        if obj.Name:lower():find("egg_victim") or obj.Name:lower():find("eggvictim") then
            local objHRP = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso") or obj.PrimaryPart
            if objHRP then
                local d = (objHRP.Position - hrp.Position).Magnitude
                if d <= maxDist and d < minDist then minDist = d; nearest = obj end
            end
        end
    end
    return nearest
end

local function findPlayerByPartialName(input)
    if not input or input == "" then return nil, "請輸入玩家名稱" end
    input = input:lower()
    local matches = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            if p.Name:lower():sub(1, #input) == input or p.DisplayName:lower():sub(1, #input) == input then
                table.insert(matches, p)
            end
        end
    end
    if #matches == 0 then return nil, "找不到玩家"
    elseif #matches == 1 then return matches[1], nil
    else
        local names = {}
        for _, p in ipairs(matches) do table.insert(names, p.Name) end
        return nil, "找到多個: " .. table.concat(names, ", ")
    end
end

local function waitNotRagdoll(getCharFn, timeout)
    timeout = timeout or 10
    local t0 = tick()
    while isRagdoll(getCharFn()) do
        if tick() - t0 > timeout then break end
        task.wait(0.1)
    end
end

-- 等目標不處於 ragdoll 持續 stableSecs 秒
local function waitStableNotRagdoll(getCharFn, stableSecs, timeout)
    stableSecs = stableSecs or 0.8
    timeout    = timeout    or 15
    local total = tick()
    while true do
        if tick() - total > timeout then return end
        -- 先等完全不是 ragdoll
        waitNotRagdoll(getCharFn, timeout - (tick() - total))
        -- 確認穩定 stableSecs 秒
        local stableStart = tick()
        local stable = true
        while tick() - stableStart < stableSecs do
            if isRagdoll(getCharFn()) then stable = false; break end
            task.wait(0.05)
        end
        if stable then return end
    end
end

