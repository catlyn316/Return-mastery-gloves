local fixPosRunning = false
local fixPosThread  = nil
local fixPosSaved   = nil
local fixPosBtn  -- forward declaration

local function stopFixPos()
    fixPosRunning = false
    if fixPosThread then pcall(function() task.cancel(fixPosThread) end); fixPosThread = nil end
    fixPosSaved = nil
    if fixPosBtn then
        setThemedBtnActive(fixPosBtn, false); fixPosBtn.Text = "啟動"
    end
    activeFeatures["固定位置"] = false; updateStatus()
end

local function startFixPos(cframe)
    stopFixPos()
    fixPosSaved   = cframe
    fixPosRunning = true
    if fixPosBtn then
        setThemedBtnActive(fixPosBtn, true); fixPosBtn.Text = "解除"
    end
    activeFeatures["固定位置"] = true; updateStatus()
    fixPosThread = trackThread(task.spawn(function()
        while fixPosRunning do
            local c = player.Character
            local h = c and c:FindFirstChild("HumanoidRootPart")
            if h and fixPosSaved then pcall(function() h.CFrame = fixPosSaved end) end
            task.wait()
        end
    end))
end

