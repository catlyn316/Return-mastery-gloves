-- ============================================================
-- 合併幫助者（供其他區使用）
-- 玩家名輸入框 + 距離 + 薩/耀模式選擇
-- ============================================================
local function makeUnifiedHelpRunner(featureKey, statusLbl, rowFrame, btn, getDistFn, getTargetInputFn, getModeInputFn)
    local running = false
    local thread  = nil

    local function resetFn()
        running = false
        if thread then pcall(function() task.cancel(thread) end); thread = nil end
        setThemedBtnActive(btn, false); btn.Text = "啟動"
        rowFrame.BackgroundColor3 = THEME.bgRow
        statusLbl.Text = "未啟動"; statusLbl.TextColor3 = THEME.textMuted
        activeFeatures[featureKey] = false; updateStatus()
    end

    btn.MouseButton1Click:Connect(function()
        running = not running
        if running then
            local tgt, err = getTargetInputFn()
            if not tgt then
                statusLbl.Text = err or "找不到目標"
                statusLbl.TextColor3 = THEME.red
                running = false
                return
            end

            setThemedBtnActive(btn, true); btn.Text = "停止"
            rowFrame.BackgroundColor3 = THEME.activeRow
            activeFeatures[featureKey] = true; updateStatus()

            thread = trackThread(task.spawn(function()
                while running do
                    local tgtPlayer = getTargetInputFn()
                    if not tgtPlayer then
                        statusLbl.Text = "找不到目標，等待…"
                        statusLbl.TextColor3 = THEME.textMuted
                        task.wait(0.5); continue
                    end

                    local myChar = player.Character
                    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
                    if not myHRP then task.wait(0.2); continue end

                    local tgtChar = tgtPlayer.Character
                    local tgtHRP  = tgtChar and tgtChar:FindFirstChild("HumanoidRootPart")

                    if tgtHRP then
                        local dist = getDistFn()
                        local frontCFrame = tgtHRP.CFrame * CFrame.new(0, 0, -dist)
                        pcall(function() myHRP.CFrame = frontCFrame end)
                        statusLbl.Text = string.format("在 %s 前方 %d 格", tgtPlayer.Name, dist)
                        statusLbl.TextColor3 = THEME.accent
                    end

                    local victim = getNearestEggVictim(30)
                    if victim then
                        statusLbl.Text = "偵測到 egg_victim，重置"
                        statusLbl.TextColor3 = THEME.green
                        pcall(function()
                            ReplicatedStorage.SelfKnockback:FireServer({
                                Direction = Vector3.new(0, 0.01, 0),
                                Force = 0
                            })
                        end)
                        task.wait(1)
                    else
                        task.wait(0.05)
                    end
                end
                resetFn()
            end))
        else
            resetFn()
        end
    end)
end

