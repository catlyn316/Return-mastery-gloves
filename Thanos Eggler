local function isRagdoll(character)
    if not character then return true end
    local hum = character:FindFirstChildOfClass("Humanoid")
    if not hum then return true end
    if hum.Health <= 0 then return true end
    local state = hum:GetState()
    if state == Enum.HumanoidStateType.FallingDown
    or state == Enum.HumanoidStateType.Ragdoll then return true end
    if character:FindFirstChild("Ragdoll") then return true end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if hrp and hrp.Anchored then return true end
    return false
end

local function getNearestPlayer()
    local char = player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local nearest, minDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
            if d < minDist then minDist = d; nearest = p end
        end
    end
    return nearest
end

-- 偵測 egg_victim，可選是否只偵測 target == 自己的（距離不限）
local function getNearestEggVictim(maxDist, selfOnly)
    local char = player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    maxDist = maxDist or math.huge
    local myName = player.Name
    local nearest, minDist = nil, math.huge

    -- 若 selfOnly 且無 hrp，仍可掃 workspace（距離不限，不需座標）
    for _, obj in ipairs(Workspace:GetChildren()) do
        if obj.Name:lower():find("egg_victim") or obj.Name:lower():find("eggvictim") then
            if selfOnly then
                local targetAttr = obj:GetAttribute("target")
                if targetAttr ~= myName then continue end
                -- selfOnly 模式：不需距離計算，直接回傳第一個符合的
                return obj
            else
                if not hrp then continue end
                local objHRP = obj:FindFirstChild("HumanoidRootPart")
                            or obj:FindFirstChild("Torso")
                            or obj.PrimaryPart
                if objHRP then
                    local d = (objHRP.Position - hrp.Position).Magnitude
                    if d <= maxDist and d < minDist then minDist = d; nearest = obj end
                end
            end
        end
    end
    return nearest
end

local function findPlayerByPartialName(input)
    if not input or input == "" then return nil, "請輸入玩家名稱" end
    input = input:lower()
    local matches = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            if p.Name:lower():sub(1, #input) == input
            or p.DisplayName:lower():sub(1, #input) == input then
                table.insert(matches, p)
            end
        end
    end
    if #matches == 0 then return nil, "找不到玩家"
    elseif #matches == 1 then return matches[1], nil
    else
        local names = {}
        for _, p in ipairs(matches) do table.insert(names, p.Name) end
        return nil, "找到多個: " .. table.concat(names, ", ")
    end
end

local function waitNotRagdoll(getCharFn, timeout)
    timeout = timeout or 10
    local t0 = tick()
    while isRagdoll(getCharFn()) do
        if tick() - t0 > timeout then break end
        task.wait(0.1)
    end
end

local function hasTool()
    local char = player.Character
    if not char then return false end
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") then return true end
    end
    local bp = player:FindFirstChildOfClass("Backpack")
    if bp then
        for _, v in ipairs(bp:GetChildren()) do
            if v:IsA("Tool") then return true end
        end
    end
    return false
end

local function teleportToLobby()
    local tp = nil
    local lobby = Workspace:FindFirstChild("Lobby")
    if lobby then
        tp = lobby:FindFirstChild("Teleport1")
        if not tp then
            for _, v in ipairs(lobby:GetDescendants()) do
                if v.Name:lower() == "teleport1" and v:IsA("BasePart") then
                    tp = v; break
                end
            end
        end
    end
    if not tp then
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v.Name:lower() == "teleport1" and v:IsA("BasePart") then
                tp = v; break
            end
        end
    end
    local c = player.Character
    local h = c and c:FindFirstChild("HumanoidRootPart")
    if h and tp then
        pcall(function() h.CFrame = tp.CFrame + Vector3.new(0, 3, 0) end)
        return true
    end
    return false
end

-- ★ 修正：優先對 Humanoid 設 Health=0，fallback 才用 FireServer
local function doSelfKill()
    local char = player.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health > 0 then
        hum.Health = 0
        return
    end
    pcall(function() Players[player.Name].Reset:FireServer() end)
end

local function waitForRespawn(timeout)
    timeout = timeout or 12
    task.wait(0.5)
    local t0 = tick()
    while tick() - t0 < timeout do
        local c   = player.Character
        local h   = c and c:FindFirstChild("HumanoidRootPart")
        local hum = c and c:FindFirstChildOfClass("Humanoid")
        if h and hum and hum.Health > 0 then break end
        task.wait(0.15)
    end
    task.wait(0.3)
end

-- ★ 模擬點擊螢幕中央（VirtualInputManager）
local function tapScreenCenter()
    local cam = Workspace.CurrentCamera
    if not cam then return end
    local vp = cam.ViewportSize
    local cx, cy = vp.X / 2, vp.Y / 2
    pcall(function()
        VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, true,  game, 0)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, false, game, 0)
    end)
end

