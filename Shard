local function toggleUIState(btn, frame, status, isActive)
    if isActive then
        btn.Text = "解除"
        btn.BackgroundColor3 = THEME.red
        frame.BackgroundColor3 = Color3.fromRGB(10, 24, 42)
        if status then status.Text = "運行中" status.TextColor3 = THEME.accent end
    else
        btn.Text = "啟動"
        btn.BackgroundColor3 = THEME.primary
        frame.BackgroundColor3 = THEME.bgRow
        if status then status.Text = "關閉" status.TextColor3 = THEME.textMuted end
    end
    updateStatus()
end

-- ============================================================
-- 攻擊邏輯：自動解任務
-- ============================================================
local function runAutoFarm()
    while toggles.autoFarm do
        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then task.wait(0.2) continue end

        -- 移到攻擊點，面對最近玩家
        hrp.CFrame = CFrame.new(applyOffset(POS_ATTACK))
        task.wait(0.3)
        faceNearest(hrp)

        -- 打第一下
        local nearest = getNearestTarget()
        if nearest and nearest.Character and nearest.Character:FindFirstChild("Left Arm") then
            pcall(function()
                ReplicatedStorage:WaitForChild("ShardHIT"):FireServer(nearest.Character:FindFirstChild("Left Arm"))
            end)
        end

        -- 移到技能點，射冰砂
        hrp.CFrame = CFrame.new(applyOffset(POS_ABILITY))
        pcall(function() ReplicatedStorage:WaitForChild("Shards"):FireServer() end)
        task.wait(1.5)
        if not toggles.autoFarm then break end

        -- 回攻擊點再打一波
        hrp.CFrame = CFrame.new(applyOffset(POS_ATTACK))
        task.wait(0.3)
        faceNearest(hrp)

        local nearest2 = getNearestTarget()
        if nearest2 and nearest2.Character and nearest2.Character:FindFirstChild("Left Arm") then
            pcall(function()
                ReplicatedStorage:WaitForChild("ShardHIT"):FireServer(nearest2.Character:FindFirstChild("Left Arm"))
            end)
        end

        task.wait(5.5)
    end
end

