local function updateStatus()
    local active = {}
    if toggles.autoFarm  then table.insert(active, "解任務中") end
    if toggles.autoShoot then table.insert(active, "射冰砂中") end
    if toggles.helpPos   then table.insert(active, "幫助中")   end
