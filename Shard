-- ============================================================
-- 相對化：偵測玩家靠近哪個安全區，決定流程座標偏移
-- 第一版安全區基準：(5122, 119, 9513)
-- 高處安全區基準：(0, 3500, 0)
-- 原始流程座標皆以「第一版安全區」為參考撰寫
-- ============================================================
local SAFE_ZONE_V1  = Vector3.new(5122, 119, 9513)
local SAFE_ZONE_HI  = Vector3.new(0,    3500, 0)
local DETECT_RADIUS = 300  -- 偵測半徑（格）

local function getSafeZoneOffset()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then
        return Vector3.new(0, 0, 0)
    end
    local pos = char.HumanoidRootPart.Position
    if (pos - SAFE_ZONE_HI).Magnitude < DETECT_RADIUS then
        -- 高處安全區：偏移 = 高處基準 - 第一版基準
        return SAFE_ZONE_HI - SAFE_ZONE_V1
    end
    -- 預設第一版安全區，偏移為零
    return Vector3.new(0, 0, 0)
end

local function applyOffset(v3)
    return v3 + getSafeZoneOffset()
end

