local function hasTool()
    local char = player.Character
    if char then
        for _, obj in ipairs(char:GetChildren()) do
            if obj:IsA("Tool") then return true end
        end
    end
    local bp = player:FindFirstChildOfClass("Backpack")
    if bp then
        for _, obj in ipairs(bp:GetChildren()) do
            if obj:IsA("Tool") then return true end
        end
    end
    return false
end

local function getHRP()
    local char = player.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    local char = player.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function teleportTo(pos)
    local hrp = getHRP()
    if hrp and hrp.Parent then
        pcall(function() hrp.CFrame = CFrame.new(pos) end)
    end
end

local function isRagdolled()
    local folder = Workspace:FindFirstChild(player.Name)
    if folder then
        local rag = folder:FindFirstChild("Ragdolled")
        if rag and rag.Value then return true end
    end
    local hum = getHumanoid()
    if hum and hum:GetState() == Enum.HumanoidStateType.Physics then return true end
    return false
end

local function waitUntilNoTool(timeout)
    local t = tick()
    while tick() - t < (timeout or 30) do
        if not toggles.bomber then return false end
        if not hasTool() then return true end
        task.wait(0.1)
    end
    return not hasTool()
end

local function waitUntilHasTool(timeout)
    local t = tick()
    while tick() - t < (timeout or 30) do
        if not toggles.bomber then return false end
        if hasTool() then return true end
        task.wait(0.1)
    end
    return hasTool()
end

local function waitUntilRagdolled(timeout)
    local t = tick()
    while tick() - t < (timeout or 20) do
        if not toggles.bomber then return false end
        if isRagdolled() then return true end
        task.wait(0.05)
    end
    return isRagdolled()
end

local function waitUntilNotRagdolled(timeout)
    local t = tick()
    while tick() - t < (timeout or 20) do
        if not toggles.bomber then return false end
        if not isRagdolled() then return true end
        task.wait(0.05)
    end
    return not isRagdolled()
end

local function ensureGloveIsBomb()
    local lb    = player:FindFirstChild("leaderboard") or player:FindFirstChild("leaderstats")
    local glove = lb and lb:FindFirstChild("Glove")
    if glove and glove.Value == "Bomb" then return end
    pcall(function() player.Reset:FireServer() end)
    waitUntilNoTool(10)
    pcall(function() fireclickdetector(Workspace.Lobby["Bomb"].ClickDetector) end)
    task.wait(1)
end

local lastToolCheckTime = tick()

local function runBomberLoop()
    lastToolCheckTime = tick()
    
    while toggles.bomber do
        ensureGloveIsBomb()
        if not toggles.bomber then break end

        local mode = values.bombMode

        if mode == "正常丟炸彈" then
            teleportTo(values.setPosition)
            task.wait(0.5)
            while toggles.bomber do
                if hasTool() then
                    lastToolCheckTime = tick()
                elseif tick() - lastToolCheckTime > 2 then
                    teleportTo(Workspace.Lobby.Teleport1.Position)
                    task.wait(0.3)
                    teleportTo(values.setPosition)
                    local fixStart = tick()
                    local hrp = getHRP()
                    if hrp and hrp.Parent then
                        local origCFrame = hrp.CFrame
                        while tick() - fixStart < 1 and toggles.bomber do
                            if hrp and hrp.Parent then
                                pcall(function() hrp.CFrame = origCFrame end)
                            end
                            task.wait(0.05)
                        end
                    end
                    lastToolCheckTime = tick()
                end
                
                pcall(function() ReplicatedStorage.BombThrow:FireServer("Ebutton") end)
                task.wait(3.1)
            end

        else
            if not hasTool() then
                local hrp = getHRP()
                if hrp and hrp.Parent then
                    pcall(function() hrp.CFrame = Workspace.Lobby.Teleport1.CFrame end)
                end
                if not waitUntilHasTool(20) then task.wait(0.5) continue end
            end
            if not toggles.bomber then break end

            teleportTo(values.setPosition)
            task.wait(0.5)
            if not toggles.bomber then break end
            
            lastToolCheckTime = tick()
            pcall(function() ReplicatedStorage.BombThrow:FireServer("Ebutton") end)

            if mode == "狙擊+炸虛空" then
                task.wait(8)
                if not toggles.bomber then break end

                local deadline = tick() + 2
                while toggles.bomber and tick() < deadline do
                    if hasTool() then
                        lastToolCheckTime = tick()
                    elseif tick() - lastToolCheckTime > 2 then
                        teleportTo(Workspace.Lobby.Teleport1.Position)
                        task.wait(0.3)
                        teleportTo(values.setPosition)
                        local fixStart = tick()
                        local hrp = getHRP()
                        if hrp and hrp.Parent then
                            local origCFrame = hrp.CFrame
                            while tick() - fixStart < 1 and toggles.bomber do
                                if hrp and hrp.Parent then
                                    pcall(function() hrp.CFrame = origCFrame end)
                                end
                                task.wait(0.05)
                            end
                        end
                        lastToolCheckTime = tick()
                    end
                    
                    local bombObj = Workspace:FindFirstChild(player.Name .. "_bømb")
                    if bombObj then
                        local hrp = getHRP()
                        if hrp and hrp.Parent then
                            pcall(function() hrp.CFrame = bombObj.CFrame end)
                        end
                    end
                    task.wait(0.05)
                end

                if toggles.bomber then
                    pcall(function() ReplicatedStorage.BombThrow:FireServer("Ebutton") end)
                end
                task.wait(0.2)

                if toggles.bomber then
                    while toggles.bomber do
                        if hasTool() then
                            lastToolCheckTime = tick()
                        elseif tick() - lastToolCheckTime > 2 then
                            teleportTo(Workspace.Lobby.Teleport1.Position)
                            task.wait(0.3)
                            teleportTo(values.setPosition)
                            local fixStart = tick()
                            local hrp = getHRP()
                            if hrp and hrp.Parent then
                                local origCFrame = hrp.CFrame
                                while tick() - fixStart < 1 and toggles.bomber do
                                    if hrp and hrp.Parent then
                                        pcall(function() hrp.CFrame = origCFrame end)
                                    end
                                    task.wait(0.05)
                                end
                            end
                            lastToolCheckTime = tick()
                        end
                        
                        local hum = getHumanoid()
                        if hum and hum.Health <= 0 then break end
                        
                        local barrier = Workspace:FindFirstChild("DEATHBARRIER")
                        if barrier then
                            local hrp = getHRP()
                            if hrp and hrp.Parent then
                                pcall(function() hrp.CFrame = barrier.CFrame end)
                            end
                        end
                        task.wait(0.05)
                    end
                end

                waitUntilNoTool(25)
                local hrp = getHRP()
                if hrp and hrp.Parent then
                    pcall(function() hrp.CFrame = Workspace.Lobby.Teleport1.CFrame end)
                end

            elseif mode == "狙擊" then
                task.wait(8)
                if not toggles.bomber then break end

                local deadline = tick() + 2
                while toggles.bomber and tick() < deadline do
                    if hasTool() then
                        lastToolCheckTime = tick()
                    elseif tick() - lastToolCheckTime > 2 then
                        teleportTo(Workspace.Lobby.Teleport1.Position)
                        task.wait(0.3)
                        teleportTo(values.setPosition)
                        local fixStart = tick()
                        local hrp = getHRP()
                        if hrp and hrp.Parent then
                            local origCFrame = hrp.CFrame
                            while tick() - fixStart < 1 and toggles.bomber do
                                if hrp and hrp.Parent then
                                    pcall(function() hrp.CFrame = origCFrame end)
                                end
                                task.wait(0.05)
                            end
                        end
                        lastToolCheckTime = tick()
                    end
                    
                    local bombObj = Workspace:FindFirstChild(player.Name .. "_bømb")
                    if bombObj then
                        local hrp = getHRP()
                        if hrp and hrp.Parent then
                            pcall(function() hrp.CFrame = bombObj.CFrame end)
                        end
                    end
                    task.wait(0.05)
                end

                if toggles.bomber then
                    pcall(function() ReplicatedStorage.BombThrow:FireServer("Ebutton") end)
                end
                task.wait(0.2)

                local raged = waitUntilRagdolled(30)
                if raged and toggles.bomber then
                    local hrp    = getHRP()
                    local fixPos = hrp and hrp.Position or values.setPosition
                    local fixLoop = task.spawn(function()
                        while toggles.bomber and isRagdolled() do
                            if hasTool() then
                                lastToolCheckTime = tick()
                            elseif tick() - lastToolCheckTime > 2 then
                                local h = getHRP()
                                if h and h.Parent then
                                    pcall(function() h.CFrame = CFrame.new(Workspace.Lobby.Teleport1.Position) end)
                                end
                                task.wait(0.3)
                                h = getHRP()
                                if h and h.Parent then
                                    pcall(function() h.CFrame = CFrame.new(values.setPosition) end)
                                end
                                local fixStart = tick()
                                while tick() - fixStart < 1 and toggles.bomber and isRagdolled() do
                                    if h and h.Parent then
                                        pcall(function() h.CFrame = CFrame.new(values.setPosition) end)
                                    end
                                    task.wait(0.05)
                                end
                                lastToolCheckTime = tick()
                            else
                                local h = getHRP()
                                if h and h.Parent then
                                    pcall(function() h.CFrame = CFrame.new(fixPos) end)
                                end
                            end
                            task.wait(0.05)
                        end
                    end)
                    waitUntilNotRagdolled(20)
                    task.cancel(fixLoop)
                end

            elseif mode == "炸虛空" then
                local bombTrackDeadline = tick() + 3.1
                local ragdollDetected = false
                
                while toggles.bomber and tick() < bombTrackDeadline and not ragdollDetected do
                    if isRagdolled() then
                        ragdollDetected = true
                        break
                    end
                    
                    if hasTool() then
                        lastToolCheckTime = tick()
                    elseif tick() - lastToolCheckTime > 2 then
                        teleportTo(Workspace.Lobby.Teleport1.Position)
                        task.wait(0.3)
                        teleportTo(values.setPosition)
                        local fixStart = tick()
                        local hrp = getHRP()
                        if hrp and hrp.Parent then
                            local origCFrame = hrp.CFrame
                            while tick() - fixStart < 1 and toggles.bomber do
                                if hrp and hrp.Parent then
                                    pcall(function() hrp.CFrame = origCFrame end)
                                end
                                task.wait(0.05)
                            end
                        end
                        lastToolCheckTime = tick()
                    end
                    
                    local bombObj = Workspace:FindFirstChild(player.Name .. "_bømb")
                    if bombObj then
                        local hrp = getHRP()
                        if hrp and hrp.Parent then
                            pcall(function() hrp.CFrame = bombObj.CFrame end)
                        end
                    end
                    task.wait(0.05)
                end

                if toggles.bomber then
                    while toggles.bomber do
                        if hasTool() then
                            lastToolCheckTime = tick()
                        elseif tick() - lastToolCheckTime > 2 then
                            teleportTo(Workspace.Lobby.Teleport1.Position)
                            task.wait(0.3)
                            teleportTo(values.setPosition)
                            local fixStart = tick()
                            local hrp = getHRP()
                            if hrp and hrp.Parent then
                                local origCFrame = hrp.CFrame
                                while tick() - fixStart < 1 and toggles.bomber do
                                    if hrp and hrp.Parent then
                                        pcall(function() hrp.CFrame = origCFrame end)
                                    end
                                    task.wait(0.05)
                                end
                            end
                            lastToolCheckTime = tick()
                        end
                        
                        local hum = getHumanoid()
                        if hum and hum.Health <= 0 then break end
                        
                        local barrier = Workspace:FindFirstChild("DEATHBARRIER")
                        if barrier then
                            local hrp = getHRP()
                            if hrp and hrp.Parent then
                                pcall(function() hrp.CFrame = barrier.CFrame end)
                            end
                        end
                        task.wait(0.05)
                    end
                end

                waitUntilNoTool(25)
                local hrp = getHRP()
                if hrp and hrp.Parent then
                    pcall(function() hrp.CFrame = Workspace.Lobby.Teleport1.CFrame end)
                end
                
                task.wait(3.1)
                if toggles.bomber then
                    pcall(function() ReplicatedStorage.BombThrow:FireServer("Ebutton") end)
                end
            end
        end

        task.wait(0.2)
    end
end

