local function switchTab(n)
    page1.Visible = (n == 1)
    page2.Visible = (n == 2)
    local tabs = { tab1, tab2 }
    for i, t in ipairs(tabs) do
        t.BackgroundColor3 = (i == n) and THEME.tabActive or THEME.tabBg
        t.TextColor3       = (i == n) and THEME.textMain  or THEME.textMuted
    end
end

