-- 觸發式按鈕列（按了就執行，不是開關）
local function createTriggerRow(parent, labelText, btnText, order)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 32)
    frame.BackgroundColor3 = THEME.bgRow
