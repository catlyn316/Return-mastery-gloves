local function createTab(text, index, total)
    local w = 1 / total
    local tab = Instance.new("TextButton")
    tab.Size = UDim2.new(w, -4, 1, -4)
    tab.Position = UDim2.new((index - 1) * w, 2, 0, 2)
    tab.BackgroundColor3 = THEME.tabBg
    tab.Text = text
    tab.TextSize = 12
    tab.Font = Enum.Font.GothamBold
    tab.TextColor3 = THEME.textMuted
    tab.Parent = tabBar
    Instance.new("UICorner", tab).CornerRadius = UDim.new(0, 4)
    return tab
end

