    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Parent = frame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)

    return frame, btn
end

-- 帶反饋的觸發按鈕（閃一下告知成功）
local function flashBtn(btn, successText, duration)
    local orig = btn.Text
    local origColor = btn.BackgroundColor3
    btn.Text = successText or "✓"
    btn.BackgroundColor3 = Color3.fromRGB(80, 180, 80)
    task.delay(duration or 0.8, function()
        if btn and btn.Parent then
            btn.Text = orig
            btn.BackgroundColor3 = origColor
        end
    end)
end

