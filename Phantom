        else
            isPosLockEnabled = false
        end
    else
        if posLockLoop then task.cancel(posLockLoop) posLockLoop = nil end
        savedPosition = nil
        fixedPosStatus.Text = "關閉"
        fixedPosStatus.TextColor3 = THEME.textMuted
        fixedPosButton.Text = "啟動"
        fixedPosButton.BackgroundColor3 = THEME.primary
        fixedPosFrame.BackgroundColor3 = THEME.bgRow
    end
    updateStatus()
end)

-- ============================================================
-- Quest 1：現身後 2 秒內攻擊（350 次）
-- 等能力冷卻 → 發動能力 → 等持續結束 → 現身後 2 秒攻擊 → 等冷卻 → 重複
-- ============================================================
local function runQuest1()
    while toggles.quest1 do
        local char = player.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then task.wait(0.2) continue end

        if not getNearestTarget() then
            q1Status.Text = "等目標" q1Status.TextColor3 = THEME.textMuted
            task.wait(0.5) continue
        end

        if not abilityReady then
            q1Status.Text = "等冷卻" q1Status.TextColor3 = THEME.textMuted
            waitAbilityReady()
            if not toggles.quest1 then break end
        end

        q1Status.Text = "能力中" q1Status.TextColor3 = THEME.accent
        useAbility()
        task.wait(ABILITY_DURATION)
        if not toggles.quest1 then break end

        q1Status.Text = "現身攻擊" q1Status.TextColor3 = THEME.green
        local windowEnd = tick() + 2.0
        while toggles.quest1 and tick() < windowEnd do
            fireHit(getTorso(getNearestTarget()))
            task.wait(values.attackInterval)
        end
    end
    q1Status.Text = "關閉" q1Status.TextColor3 = THEME.textMuted
end

-- ============================================================
-- Quest 2：打人 → 隱身 → 趁隱身再打同一人（200 次）
-- 等能力冷卻 → 攻擊目標一次 → 立刻能力 → 隱身中持續攻擊同一目標 → 等冷卻 → 重複
-- ============================================================
local function runQuest2()
    while toggles.quest2 do
        local char = player.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then task.wait(0.2) continue end

        local tgt = getNearestTarget()
        if not tgt then
            q2Status.Text = "等目標" q2Status.TextColor3 = THEME.textMuted
            task.wait(0.5) continue
        end

        if not abilityReady then
            q2Status.Text = "等冷卻" q2Status.TextColor3 = THEME.textMuted
            waitAbilityReady()
            if not toggles.quest2 then break end
        end

        -- 先打一次
        q2Status.Text = "初次攻擊" q2Status.TextColor3 = THEME.accent
        fireHit(getTorso(tgt))
        task.wait(0.1)
        if not toggles.quest2 then break end

        -- 立刻發動能力（隱身）
        q2Status.Text = "隱身攻擊" q2Status.TextColor3 = THEME.green
        useAbility()

        -- 隱身期間持續打同一目標
        local abilityEnd = tick() + ABILITY_DURATION
        while toggles.quest2 and tick() < abilityEnd do
            fireHit(getTorso(tgt))
            task.wait(values.attackInterval)
        end
        if not toggles.quest2 then break end

        q2Status.Text = "等冷卻" q2Status.TextColor3 = THEME.textMuted
        waitAbilityReady()
    end
    q2Status.Text = "關閉" q2Status.TextColor3 = THEME.textMuted
end

-- ============================================================
-- Quest 3：碰撞後攻擊不死 10 次連續
-- 距離 <= 5 視為碰撞 → 立刻攻擊 計數+1
-- 死亡 → 計數歸零
-- 到 10 次 → 重置計數繼續
-- ============================================================
local function runQuest3()
    values.quest3Count = 0
    local lastHitTime = 0
    local HIT_COOLDOWN = 1.0
    local deathConn = nil
    local respawnConn = nil

    local function setupDeathConn()
        if deathConn then pcall(function() deathConn:Disconnect() end) deathConn = nil end
        local char = player.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        deathConn = hum.Died:Connect(function()
            values.quest3Count = 0
            q3Status.Text = "死亡歸零" q3Status.TextColor3 = THEME.red
            updateStatus()
        end)
    end

    setupDeathConn()
    respawnConn = player.CharacterAdded:Connect(function()
        task.wait(1)
        if toggles.quest3 then setupDeathConn() end
    end)

    while toggles.quest3 do
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then task.wait(0.2) continue end

        local tgt = getNearestTarget()
        if not tgt then
            q3Status.Text = "等目標" q3Status.TextColor3 = THEME.textMuted
            task.wait(0.5) continue
        end

        local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
        if not tgtRoot then task.wait(0.1) continue end

        if (tgtRoot.Position - hrp.Position).Magnitude <= 5 and (tick() - lastHitTime) >= HIT_COOLDOWN then
            lastHitTime = tick()
            fireHit(getTorso(tgt))
            values.quest3Count = values.quest3Count + 1
            updateStatus()
            if values.quest3Count >= 10 then
                q3Status.Text = "10次完成！" q3Status.TextColor3 = THEME.green
                task.wait(1)
                values.quest3Count = 0
                updateStatus()
            else
                q3Status.Text = values.quest3Count.."/10" q3Status.TextColor3 = THEME.accent
            end
        end

        task.wait(0.05)
    end

    if deathConn then pcall(function() deathConn:Disconnect() end) end
    if respawnConn then pcall(function() respawnConn:Disconnect() end) end
    q3Status.Text = "關閉" q3Status.TextColor3 = THEME.textMuted
end

