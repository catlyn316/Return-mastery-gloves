helpTargetButton.MouseButton1Click:Connect(function()
    toggles.helpTarget = not toggles.helpTarget

    if toggles.helpTarget then
        local targetPlayer, errorMsg = findPlayerByPartialName(helpTargetInput.Text)
        if not targetPlayer then
            helpTargetInfo.Text = errorMsg or "找不到玩家"
            helpTargetInfo.TextColor3 = Color3.fromRGB(200, 0, 0)
            toggles.helpTarget = false
            return
        end

        values.targetPlayer = targetPlayer
        helpTargetInfo.Text = "目標: " .. targetPlayer.Name
        helpTargetInfo.TextColor3 = THEME.accent

        connections.helpTarget = task.spawn(function()

            local function waitForAliveCharacter(timeout)
                local t = tick()
                while tick() - t < (timeout or 15) do
                    if not toggles.helpTarget then return nil, nil, nil end
                    local c = player.Character
                    if c then
                        local hrp = c:FindFirstChild("HumanoidRootPart")
                        local hum = c:FindFirstChildOfClass("Humanoid")
                        if hrp and hum and hum.Health > 0 then return c, hrp, hum end
                    end
                    task.wait(0.2)
                end
                return nil, nil, nil
            end

            local function teleportToLobby(hrp)
                pcall(function()
                    local tp1 = Workspace.Lobby:FindFirstChild("Teleport1")
                    if tp1 and hrp and hrp.Parent then hrp.CFrame = tp1.CFrame end
                end)
            end

            local function teleportToTarget(hrp, tgt)
                pcall(function()
                    if not (hrp and hrp.Parent) then return end
                    local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                    if tgtRoot then
                        local lookDir = tgtRoot.CFrame.LookVector
                        local newPos = tgtRoot.Position + (lookDir * values.helpDistance)
                        local newCFrame = CFrame.new(newPos, newPos + lookDir)
                        hrp.CFrame = newCFrame
                        values.fixedCFrame = newCFrame
                    end
                end)
            end

            while toggles.helpTarget do
                local tgt = values.targetPlayer
                local _, hrp, hum = waitForAliveCharacter(15)
                if not hrp then task.wait(0.5) continue end
                if not toggles.helpTarget then break end

                local savedFixedCFrame = values.fixedCFrame
                values.fixedCFrame = nil
                teleportToLobby(hrp)
                task.wait(0.5)
                if not toggles.helpTarget then break end
                values.fixedCFrame = savedFixedCFrame

                local teleportSuccess = false
                local tpStart = tick()
                while toggles.helpTarget and tick() - tpStart < 5 do
                    teleportToTarget(hrp, tgt)
                    pcall(function()
                        local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                        if tgtRoot and hrp and hrp.Parent then
                            if (tgtRoot.Position - hrp.Position).Magnitude <= (values.helpDistance + 5) then
                                teleportSuccess = true
                            end
                        end
                    end)
                    if teleportSuccess then break end
                    task.wait(0.5)
                end
                if not toggles.helpTarget then break end
                if not teleportSuccess then continue end

                local lobbyStuck = false
                local helpDone = false
                local lobbyStuckTimer = 0
                local lastCheckPos = nil

                local lobbyStuckLoop = task.spawn(function()
                    while not helpDone and toggles.helpTarget do
                        local myPos = hrp and hrp.Parent and hrp.Position
                        if myPos then
                            if not lastCheckPos then lastCheckPos = myPos end
                            local notMoving = (myPos - lastCheckPos).Magnitude <= 10
                            local nearRamp = false
                            pcall(function()
                                local lobby = Workspace:FindFirstChild("Lobby")
                                if lobby then
                                    for _, obj in ipairs(lobby:GetChildren()) do
                                        if obj.Name == "LobbyRamp" then
                                            local parts = obj:IsA("BasePart") and {obj} or {}
                                            if #parts == 0 then for _, p in ipairs(obj:GetDescendants()) do if p:IsA("BasePart") then table.insert(parts, p) end end end
                                            for _, part in ipairs(parts) do
                                                if (part.Position - myPos).Magnitude <= 50 then nearRamp = true break end
                                            end
                                        end
                                        if nearRamp then break end
                                    end
                                end
                            end)
                            if notMoving and nearRamp then
                                lobbyStuckTimer = lobbyStuckTimer + 0.2
                                if lobbyStuckTimer >= 5 then lobbyStuck = true helpDone = true end
                            else
                                lobbyStuckTimer = 0 lastCheckPos = myPos
                            end
                        end
                        task.wait(0.2)
                    end
                end)

                local noToolTimer = 0
                local noToolLoop = task.spawn(function()
                    while not helpDone and toggles.helpTarget do
                        local character = player.Character
                        local hasTool = false
                        if character then
                            for _, obj in ipairs(character:GetChildren()) do if obj:IsA("Tool") then hasTool = true break end end
                            local bp = player:FindFirstChildOfClass("Backpack")
                            if bp then for _, obj in ipairs(bp:GetChildren()) do if obj:IsA("Tool") then hasTool = true break end end end
                        end
                        if not hasTool then
                            noToolTimer = noToolTimer + 0.1
                            if noToolTimer >= 0.5 then lobbyStuck = true helpDone = true end
                        else noToolTimer = 0 end
                        task.wait(0.1)
                    end
                end)

                if values.helpMode == "被打後不重置" then
                    local helpConn = task.spawn(function()
                        runHelpLoopNoReset(hrp, hum, tgt, function() helpDone = true end)
                    end)
                    while not helpDone and toggles.helpTarget do task.wait(0.1) end
                    task.cancel(helpConn)
                else
                    local helpConn = task.spawn(function()
                        runHelpLoopSlappedReset(hrp, hum, tgt, function() helpDone = true end)
                    end)
                    while not helpDone and toggles.helpTarget do task.wait(0.1) end
                    task.cancel(helpConn)
                end

                helpDone = true
                task.cancel(lobbyStuckLoop)
                task.cancel(noToolLoop)

                if lobbyStuck and toggles.helpTarget then
                    teleportToLobby(hrp)
                    task.wait(0.5)
                end
            end
        end)

        helpTargetButton.Text = "解除"
        helpTargetButton.BackgroundColor3 = THEME.red
        helpTargetFrame.BackgroundColor3 = Color3.fromRGB(22, 10, 42)
    else
        helpTargetInfo.Text = "目標: 無"
        helpTargetInfo.TextColor3 = THEME.textMuted
        values.targetPlayer = nil
        if connections.helpTarget then task.cancel(connections.helpTarget) connections.helpTarget = nil end
        helpTargetButton.Text = "啟動"
        helpTargetButton.BackgroundColor3 = THEME.primary
        helpTargetFrame.BackgroundColor3 = THEME.bgRow
    end
    updateStatus()
end)

-- ============================================================
-- 拖曳
-- ============================================================
local function enableDrag(frame, dragHandle)
    local dragging, dragStart, startPos, dragInput = false, nil, nil, nil
    local function update(input)
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true dragStart = input.Position startPos = frame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    dragHandle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then update(input) end
    end)
end

