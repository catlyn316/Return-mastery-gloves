-- ============================================================
local lockedTarget      = nil
local faceTargetLoop    = nil
local faceTargetRunning = false

local function startFaceTargetLoop()
    if faceTargetRunning then return end
    faceTargetRunning = true
    if not lockedTarget then lockedTarget = getNearestTarget() end
    faceTargetLoop = task.spawn(function()
        while faceTargetRunning do
            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp and lockedTarget and lockedTarget.Character and lockedTarget.Character:FindFirstChild("HumanoidRootPart") then
                local targetPos = lockedTarget.Character.HumanoidRootPart.Position
                local lookCFrame = CFrame.new(hrp.Position, Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z))
                pcall(function() hrp.CFrame = lookCFrame end)
            end
            task.wait(0.05)
        end
    end)
end

local function stopFaceTargetLoop()
    if not toggles.attacker then
        faceTargetRunning = false
        if faceTargetLoop then task.cancel(faceTargetLoop) faceTargetLoop = nil end
        lockedTarget = nil
    end
end

-- ============================================================
-- 攻擊者主邏輯
-- 流程：
--   1. 鎖定最近目標
--   2. 攻擊一次（PhantomHit）
--   3. 立刻發動能力（PhantomDash）隱身 2.5 秒
--   4. 2.5 秒內持續攻擊同一目標（每 attackInterval 秒）
--   5. 等隱身結束後 6 秒冷卻
--   6. 重複
-- ============================================================
local function runAttackerLoop()
    while toggles.attacker do
        local char = player.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then task.wait(0.2) continue end

        local target = getNearestTarget()
        if not target or not target.Character then
            phaseStatus.Text = "找目標中"
            phaseStatus.TextColor3 = THEME.textMuted
            task.wait(0.2)
            continue
        end

        local targetName = target.Name

        -- 步驟1：攻擊一次
        phaseStatus.Text = "攻擊中"
        phaseStatus.TextColor3 = THEME.accent
        pcall(function()
            local torso = target.Character and target.Character:FindFirstChild("Torso")
            if torso then ReplicatedStorage.PhantomHit:FireServer(torso) end
        end)
        task.wait(0.1)
        if not toggles.attacker then break end

        -- 步驟2：立刻發動能力隱身
        pcall(function()
            local phantom = player.Character and player.Character:FindFirstChild("Phantom")
            if phantom then
                ReplicatedStorage.PhantomDash:InvokeServer(phantom)
            end
        end)

        -- 步驟3：2.5 秒隱身期間持續攻擊
        local dashEnd = tick() + 2.5
        while tick() < dashEnd and toggles.attacker do
            local remaining = math.floor((dashEnd - tick()) * 10) / 10
            phaseStatus.Text = "隱身攻擊(" .. remaining .. "s)"
            phaseStatus.TextColor3 = Color3.fromRGB(180, 100, 255)
            pcall(function()
                local tgt = Players:FindFirstChild(targetName)
                local torso = tgt and tgt.Character and tgt.Character:FindFirstChild("Torso")
                if torso then ReplicatedStorage.PhantomHit:FireServer(torso) end
            end)
            task.wait(values.attackInterval)
        end
        if not toggles.attacker then break end

        -- 步驟4：6 秒冷卻
        local cooldownEnd = tick() + 6.0
        while tick() < cooldownEnd and toggles.attacker do
            local remaining = math.ceil(cooldownEnd - tick())
            phaseStatus.Text = "冷卻中(" .. remaining .. "s)"
            phaseStatus.TextColor3 = THEME.textMuted
            task.wait(0.2)
        end
    end
    phaseStatus.Text = "待機"
    phaseStatus.TextColor3 = THEME.textMuted
end

attackerButton.MouseButton1Click:Connect(function()
    toggles.attacker = not toggles.attacker
    if toggles.attacker then
        lockedTarget = getNearestTarget()
        startFaceTargetLoop()
        connections.attacker = task.spawn(runAttackerLoop)
    else
        if connections.attacker then task.cancel(connections.attacker) connections.attacker = nil end
        stopFaceTargetLoop()
        phaseStatus.Text = "待機"
        phaseStatus.TextColor3 = THEME.textMuted
    end
    toggleUIState(attackerButton, attackerFrame, attackerStatus, toggles.attacker, "運行中", "關閉")
end)

