local function findPlayerByPartialName(input)
    if not input or input == "" then return nil, "請輸入玩家名稱" end
    input = input:lower()
    local matches = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            if p.Name:lower():sub(1, #input) == input or p.DisplayName:lower():sub(1, #input) == input then
                table.insert(matches, p)
            end
        end
    end
    if #matches == 0 then return nil, "找不到玩家"
    elseif #matches == 1 then return matches[1], nil
    else
        local names = {}
        for _, p in ipairs(matches) do table.insert(names, p.Name) end
        return nil, "找到多個玩家: " .. table.concat(names, ", ") .. "\n請輸入更多字元"
    end
end

local function getNearestTarget()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = char.HumanoidRootPart.Position
    local nearest, minDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (p.Character.HumanoidRootPart.Position - myPos).Magnitude
            if d < minDist then minDist = d nearest = p end
        end
    end
    return nearest
end

local function getTorso(p)
    return p and p.Character and p.Character:FindFirstChild("Torso")
end

local function fireHit(torso)
    if not torso then return end
    pcall(function() ReplicatedStorage.PhantomHit:FireServer(torso) end)
end

-- 發動能力，回傳是否成功
local function useAbility()
    if not abilityReady then return false end
    local char = player.Character
    local phantom = char and char:FindFirstChild("Phantom")
    if not phantom then return false end
    abilityReady = false
    pcall(function() ReplicatedStorage.PhantomDash:InvokeServer(phantom) end)
    -- 持續時間結束後才開始冷卻，冷卻結束後設 ready
    task.spawn(function()
        task.wait(ABILITY_DURATION + ABILITY_COOLDOWN)
        abilityReady = true
    end)
    return true
end

local function waitAbilityReady()
    while not abilityReady do task.wait(0.1) end
end

