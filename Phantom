-- ============================================================
-- 幫助者位置迴圈：被打後不重置
-- ============================================================
local function runHelpLoopNoReset(hrp, hum, tgt, onDone)
    while toggles.helpTarget do
        if not (hrp and hrp.Parent) then break end
        if hum.Health <= 0 then break end
        pcall(function()
            if toggles.fixedPosHelp and values.fixedCFrame then
                hrp.CFrame = values.fixedCFrame
            elseif not toggles.fixedPosHelp then
                local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                if tgtRoot then
                    local lookDir = tgtRoot.CFrame.LookVector
                    local newPos = tgtRoot.Position + (lookDir * values.helpDistance)
                    hrp.CFrame = CFrame.new(newPos, newPos + lookDir)
                end
            end
        end)
        task.wait()
    end
    onDone()
end

-- ============================================================
-- 幫助者位置迴圈：被打時重置
-- 監聽 folder.ChildAdded，LastSlappedBy 出現且是目標時重置
-- ============================================================
local function runHelpLoopSlappedReset(hrp, hum, tgt, onDone)
    local resetTriggered = false
    local folderConn = nil

    local function doReset()
        if resetTriggered then return end
        resetTriggered = true
        if folderConn then pcall(function() folderConn:Disconnect() end) end
        pcall(function() Players.LocalPlayer.Reset:FireServer() end)
        task.wait(0.1)
        onDone()
    end

    local function setupFolderConn()
        if folderConn then pcall(function() folderConn:Disconnect() end) end
        pcall(function()
            local folder = Workspace:FindFirstChild(player.Name)
            if not folder then return end
            folderConn = folder.ChildAdded:Connect(function(child)
                if resetTriggered then return end
                if child.Name == "LastSlappedBy" and tostring(child.Value) == tgt.Name then
                    doReset()
                end
            end)
        end)
    end

    setupFolderConn()

    while toggles.helpTarget and not resetTriggered do
        if not (hrp and hrp.Parent) then break end
        if hum.Health <= 0 then break end
        if not folderConn then setupFolderConn() end
        pcall(function()
            if toggles.fixedPosHelp and values.fixedCFrame then
                hrp.CFrame = values.fixedCFrame
            elseif not toggles.fixedPosHelp then
                local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                if tgtRoot then
                    local lookDir = tgtRoot.CFrame.LookVector
                    local newPos = tgtRoot.Position + (lookDir * values.helpDistance)
                    hrp.CFrame = CFrame.new(newPos, newPos + lookDir)
                end
            end
        end)
        task.wait(0.05)
    end

    if folderConn then pcall(function() folderConn:Disconnect() end) end
    if not resetTriggered then onDone() end
end

