-- ② Ragdoll 偵測
-- ============================================================
local ragdolledConn = nil

local function setupRagdollDetection()
    if ragdolledConn then pcall(function() ragdolledConn:Disconnect() end) end
    ragdolledConn = nil
    isRagdolled   = false
    spinPaused    = false

    local function tryConnectRagdolledValue()
        local folder = Workspace:FindFirstChild(player.Name)
        if folder then
            local rv = folder:FindFirstChild("Ragdolled")
            if rv then
                ragdolledConn = rv.Changed:Connect(function(val)
                    isRagdolled = (val == true)
                    spinPaused  = isRagdolled
                end)
                return true
            end
        end
        return false
    end

    if not tryConnectRagdolledValue() then
        local char = player.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                ragdolledConn = hum.StateChanged:Connect(function(_, newState)
                    if newState == Enum.HumanoidStateType.FallingDown
                    or newState == Enum.HumanoidStateType.Ragdoll then
                        isRagdolled = true
                        spinPaused  = true
                    elseif newState == Enum.HumanoidStateType.GettingUp
                    or     newState == Enum.HumanoidStateType.Running
                    or     newState == Enum.HumanoidStateType.Landed then
                        isRagdolled = false
                        spinPaused  = false
                    end
                end)
            end
        end
    end
end

player.CharacterAdded:Connect(function()
    task.wait(0.5)
    setupRagdollDetection()
end)

if player.Character then setupRagdollDetection() end

-- ============================================================
-- ③ 旋轉邏輯（Spin 15 rad/s）
-- ============================================================
local spinBAV = nil

local function removeSpinBAV()
    if spinBAV and spinBAV.Parent then
        spinBAV:Destroy()
    end
    spinBAV = nil
end

local function applySpinBAV(hrp, angVelY)
    removeSpinBAV()
    local bav = Instance.new("BodyAngularVelocity")
    bav.AngularVelocity = Vector3.new(0, angVelY, 0)
    bav.MaxTorque       = Vector3.new(0, math.huge, 0)
    bav.P               = math.huge
    bav.Parent          = hrp
    spinBAV = bav
end

-- Glove CanCollide 控制
-- setGloveCanCollide(false) = 旋轉中（攻擊狀態）
-- setGloveCanCollide(true)  = 停止/間歇（安全狀態）
local function setGloveCanCollide(state)
    pcall(function()
        local char  = player.Character
        if not char then return end
        local tool  = char:FindFirstChild("Mace")
        if not tool then return end
        local glove = tool:FindFirstChild("Glove")
        if not glove then return end
        glove.CanCollide = state
    end)
end

local function runSpinLoop()
    task.wait(0.05)
    while toggles.manualSpin do
        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")

        if not hrp then
            removeSpinBAV()
            setGloveCanCollide(true)   -- 角色不存在 → 恢復碰撞
            task.wait(0.1)
            continue
        end

        if spinPaused then
            -- Ragdoll 中：停止旋轉，恢復碰撞
            removeSpinBAV()
            setGloveCanCollide(true)
            task.wait(0.05)
            continue
        end

        if values.spinMode == "正常轉" then
            -- 確保 BAV 存在；CanCollide = false（攻擊中）
            if not spinBAV or not spinBAV.Parent then
                applySpinBAV(hrp, 15)
                setGloveCanCollide(false)
            end
            task.wait(0.1)
        else
            -- 間隔轉：旋轉 1.5 秒（CanCollide false）
            applySpinBAV(hrp, 15)
            setGloveCanCollide(false)
            local t0 = tick()
            while tick() - t0 < 1.5 do
                if not toggles.manualSpin then
                    removeSpinBAV()
                    setGloveCanCollide(true)   -- 開關被關 → 恢復碰撞
                    return
                end
                if spinPaused then
                    removeSpinBAV()
                    setGloveCanCollide(true)   -- Ragdoll → 恢復碰撞
                    break
                end
                task.wait(0.05)
            end
            if not toggles.manualSpin then
                removeSpinBAV()
                setGloveCanCollide(true)
                return
            end

            -- 間歇期 1.5 秒（CanCollide true）
            removeSpinBAV()
            setGloveCanCollide(true)           -- 進入間歇 → 恢復碰撞
            local t1 = tick()
            while tick() - t1 < 1.5 do
                if not toggles.manualSpin then
                    -- 間歇期中被關閉，CanCollide 已是 true，直接離開
                    return
                end
                task.wait(0.05)
            end
            -- 間歇結束，下一圈會再設 CanCollide = false
        end
    end
    -- 旋轉完全停止
    removeSpinBAV()
    setGloveCanCollide(true)
end

-- ============================================================
-- ④ 攻擊固定位置（BodyPosition 鎖 XYZ，不限制旋轉）
--    與 BodyAngularVelocity 同時存在，兩者獨立運作
-- ============================================================
local fixedBP     = nil   -- 目前掛在 HRP 上的 BodyPosition
local fixedTarget = nil   -- 儲存要固定的座標 Vector3

local function removeFixedBP()
    if fixedBP and fixedBP.Parent then
        fixedBP:Destroy()
    end
    fixedBP = nil
end

local function applyFixedBP(hrp, pos)
    removeFixedBP()
    local bp = Instance.new("BodyPosition")
    bp.Position  = pos
    bp.MaxForce  = Vector3.new(1e5, 1e5, 1e5)   -- 足夠大但不至於飛出去
    bp.D         = 1000                           -- 阻尼，讓位置平滑
    bp.P         = 10000
    bp.Parent    = hrp
    fixedBP      = bp
end

local function runFixedPosLoop()
    -- 啟動時先記錄當前位置
    local char = player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        fixedTarget = hrp.Position
        applyFixedBP(hrp, fixedTarget)
    end

    while toggles.fixedAttackPos do
        local c   = player.Character
        local h   = c and c:FindFirstChild("HumanoidRootPart")
        if not h then
            removeFixedBP()
            task.wait(0.1)
            -- 角色重生後重新抓位置
            local t = tick()
            while toggles.fixedAttackPos and tick() - t < 10 do
                local c2 = player.Character
                local h2 = c2 and c2:FindFirstChild("HumanoidRootPart")
                if h2 then
                    -- 重生後重新設定 BodyPosition（位置維持原定點）
                    fixedTarget = fixedTarget  -- 維持上一次記錄的座標
                    applyFixedBP(h2, fixedTarget)
                    break
                end
                task.wait(0.2)
            end
            task.wait(0.1)
            continue
        end

        -- 確保 BodyPosition 還在
        if not fixedBP or not fixedBP.Parent then
            if fixedTarget then
                applyFixedBP(h, fixedTarget)
            end
        end

        task.wait(0.05)
    end

    removeFixedBP()
end

