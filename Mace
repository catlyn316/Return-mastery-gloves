local function updateStatusBar()
    local active = {}
    if toggles.manualSpin      then table.insert(active, "旋轉中") end
    if toggles.fixedAttackPos  then table.insert(active, "固定中") end
    if toggles.helpTarget      then table.insert(active, "幫助中") end
    if #active > 0 then
        statusLabel.Text       = "✅ " .. table.concat(active, " | ")
        statusLabel.TextColor3 = THEME.accent
    else
        statusLabel.Text       = "系統就緒"
        statusLabel.TextColor3 = THEME.primary
    end
end

local function setRowActive(btn, frame, status, isActive, activeText, inactiveText)
    if isActive then
        btn.Text             = "解除"
        btn.BackgroundColor3 = THEME.red
        frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        if status then
            status.Text       = activeText or "運行中"
            status.TextColor3 = THEME.accent
        end
    else
        btn.Text             = "啟動"
        btn.BackgroundColor3 = THEME.primary
        frame.BackgroundColor3 = THEME.bgRow
        if status then
            status.Text       = inactiveText or "關閉"
            status.TextColor3 = THEME.textMuted
        end
    end
    updateStatusBar()
end

