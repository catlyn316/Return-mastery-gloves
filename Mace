miniTitle.Size              = UDim2.new(1, -36, 1, 0)
miniTitle.Position          = UDim2.new(0, 0, 0, 0)
miniTitle.BackgroundTransparency = 1
miniTitle.Font              = Enum.Font.GothamBold
miniTitle.TextSize          = 13
miniTitle.TextColor3        = THEME.accent
miniTitle.TextXAlignment    = Enum.TextXAlignment.Center
miniTitle.Parent            = miniFrame

local expandBtn = Instance.new("TextButton")
expandBtn.Text             = "+"
expandBtn.Size             = UDim2.new(0, 24, 0, 24)
expandBtn.Position         = UDim2.new(1, -28, 0, 4)
expandBtn.BackgroundColor3 = THEME.primary
expandBtn.TextColor3       = Color3.new(1, 1, 1)
expandBtn.Font             = Enum.Font.GothamBold
expandBtn.Parent           = miniFrame
Instance.new("UICorner", expandBtn).CornerRadius = UDim.new(0, 5)

enableDrag(miniFrame, miniFrame)

minimizeBtn.MouseButton1Click:Connect(function()
    mainFrame.Visible = false
    miniFrame.Visible = true
end)
expandBtn.MouseButton1Click:Connect(function()
    miniFrame.Visible = false
    mainFrame.Visible = true
end)

-- ============================================================
-- 關閉按鈕
-- ============================================================
closeBtn.MouseButton1Click:Connect(function()
    for key, t in pairs(threads) do
        if t then
            pcall(function() task.cancel(t) end)
            threads[key] = nil
        end
    end
    if ragdolledConn then pcall(function() ragdolledConn:Disconnect() end) end
    removeSpinBAV()
    removeFixedBP()
    setGloveCanCollide(true)   -- 關閉腳本時恢復碰撞
    screenGui:Destroy()
end)

-- ============================================================
-- 初始化完成
-- ============================================================
print("貓玲的槌球腳本 v0.3 已載入！")
