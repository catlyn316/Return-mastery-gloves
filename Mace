local function findPlayerByPartialName(input)
    if not input or input == "" then return nil, "請輸入玩家名稱" end
    input = input:lower()
    local matches = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            if p.Name:lower():sub(1, #input) == input
            or p.DisplayName:lower():sub(1, #input) == input then
                table.insert(matches, p)
            end
        end
    end
    if #matches == 0    then return nil, "找不到玩家"
    elseif #matches > 1 then
        local names = {}
        for _, p in ipairs(matches) do table.insert(names, p.Name) end
        return nil, "找到多個: " .. table.concat(names, ", ")
    end
    return matches[1], nil
end

-- LastSlappedBy 讀取輔助
local function getLastSlappedBy()
    local result = nil
    pcall(function()
        local folder = Workspace:FindFirstChild(player.Name)
        if folder then
            local lsb = folder:FindFirstChild("LastSlappedBy")
            if lsb then result = lsb.Value end
        end
    end)
    return result
end

