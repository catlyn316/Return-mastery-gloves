local function runHelpLoopNoReset(hrp, hum, tgt)
    while toggles.helpTarget do
        if not (hrp and hrp.Parent) then break end
        if hum.Health <= 0 then break end
        pcall(function()
            if toggles.fixedPosHelp and values.fixedCFrame then
                hrp.CFrame = values.fixedCFrame
            elseif not toggles.fixedPosHelp then
                local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                if tgtRoot then
                    local ld  = tgtRoot.CFrame.LookVector
                    local pos = tgtRoot.Position + ld * values.helpDistance
                    hrp.CFrame = CFrame.new(pos, pos + ld)
                end
            end
        end)
        task.wait()
    end
end

-- ============================================================
-- 幫助者位置保持：被打後重置（僅目標打才重置）
--   判定：ragdoll = true 時檢查 LastSlappedBy == 目標名字
-- ============================================================
local function runHelpLoopRagdollReset(hrp, hum, tgt)
    local ragdolledObj = nil
    pcall(function()
        local folder = Workspace:FindFirstChild(player.Name)
        if folder then ragdolledObj = folder:FindFirstChild("Ragdolled") end
    end)

    local shouldReset    = false
    local ragdollConn    = nil

    local function onRagdolled(val)
        if val ~= true then return end
        -- 檢查 LastSlappedBy 是否等於目標玩家名字
        local slappedBy = getLastSlappedBy()
        if slappedBy == tgt.Name or slappedBy == tgt.DisplayName then
            shouldReset = true
        end
        -- 不是目標打的 → 不重置，繼續保持位置
    end

    local function setupConn()
        if ragdollConn then pcall(function() ragdollConn:Disconnect() end) end
        if not ragdolledObj or not ragdolledObj.Parent then return end
        ragdollConn = ragdolledObj.Changed:Connect(onRagdolled)
    end

    setupConn()

    while toggles.helpTarget do
        if not (hrp and hrp.Parent) then break end
        if hum.Health <= 0 then break end

        -- 若 ragdolledObj 丟失，嘗試重新取得
        if not ragdolledObj or not ragdolledObj.Parent then
            pcall(function()
                local folder = Workspace:FindFirstChild(player.Name)
                if folder then ragdolledObj = folder:FindFirstChild("Ragdolled") end
            end)
            setupConn()
        end

        if shouldReset then
            shouldReset = false
            if ragdollConn then pcall(function() ragdollConn:Disconnect() end) end
            task.wait(0.1)
            pcall(function() player.Reset:FireServer() end)
            task.wait(0.1)
            break  -- 本輪結束，外層迴圈會重新傳送
        end

        pcall(function()
            if toggles.fixedPosHelp and values.fixedCFrame then
                hrp.CFrame = values.fixedCFrame
            elseif not toggles.fixedPosHelp then
                local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                if tgtRoot then
                    local ld  = tgtRoot.CFrame.LookVector
                    local pos = tgtRoot.Position + ld * values.helpDistance
                    hrp.CFrame = CFrame.new(pos, pos + ld)
                end
            end
        end)
        task.wait(0.05)
    end

    if ragdollConn then pcall(function() ragdollConn:Disconnect() end) end
end

-- ============================================================
-- 幫助者主邏輯（外層：傳送 + 選擇模式分支）
-- ============================================================
local function runHelpLoop(tgt)
    local function waitAlive(timeout)
        local t = tick()
        while tick() - t < (timeout or 15) do
            if not toggles.helpTarget then return nil, nil end
            local c = player.Character
            if c then
                local hrp = c:FindFirstChild("HumanoidRootPart")
                local hum = c:FindFirstChildOfClass("Humanoid")
                if hrp and hum and hum.Health > 0 then return hrp, hum end
            end
            task.wait(0.2)
        end
        return nil, nil
    end

    local function teleportToLobby(hrp)
        pcall(function()
            local tp1 = Workspace.Lobby and Workspace.Lobby:FindFirstChild("Teleport1")
            if tp1 and hrp and hrp.Parent then hrp.CFrame = tp1.CFrame end
        end)
    end

    local function teleportToTarget(hrp)
        pcall(function()
            if not (hrp and hrp.Parent) then return end
            local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
            if tgtRoot then
                local lookDir = tgtRoot.CFrame.LookVector
                local newPos  = tgtRoot.Position + lookDir * values.helpDistance
                local cf      = CFrame.new(newPos, newPos + lookDir)
                hrp.CFrame    = cf
                values.fixedCFrame = cf
            end
        end)
    end

    while toggles.helpTarget do
        local hrp, hum = waitAlive(15)
        if not hrp then task.wait(0.5) continue end
        if not toggles.helpTarget then break end

        -- 傳送流程
        values.fixedCFrame = nil
        teleportToLobby(hrp)
        task.wait(0.5)
        if not toggles.helpTarget then break end

        local tpSuccess = false
        local tpStart   = tick()
        while toggles.helpTarget and tick() - tpStart < 5 do
            teleportToTarget(hrp)
            pcall(function()
                local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                if tgtRoot and hrp and hrp.Parent then
                    if (tgtRoot.Position - hrp.Position).Magnitude <= values.helpDistance + 5 then
                        tpSuccess = true
                    end
                end
            end)
            if tpSuccess then break end
            task.wait(0.5)
        end
        if not toggles.helpTarget or not tpSuccess then continue end

        local helpDone   = false
        local lobbyStuck = false

        -- 無 Tool 偵測（大廳卡住偵測）
        local noToolTimer  = 0
        local noToolThread = task.spawn(function()
            while not helpDone and toggles.helpTarget do
                local hasTool = false
                local c = player.Character
                if c then
                    for _, v in ipairs(c:GetChildren()) do
                        if v:IsA("Tool") then hasTool = true break end
                    end
                    local bp = player:FindFirstChildOfClass("Backpack")
                    if bp and not hasTool then
                        for _, v in ipairs(bp:GetChildren()) do
                            if v:IsA("Tool") then hasTool = true break end
                        end
                    end
                end
                noToolTimer = hasTool and 0 or noToolTimer + 0.1
                if noToolTimer >= 0.5 then lobbyStuck = true helpDone = true end
                task.wait(0.1)
            end
        end)

        -- 根據幫助模式選擇不同的位置保持分支
        if values.helpMode == "被打後不重置" then
            local helpConn = task.spawn(function()
                runHelpLoopNoReset(hrp, hum, tgt)
                helpDone = true
            end)
            while not helpDone and toggles.helpTarget do task.wait(0.1) end
            pcall(function() task.cancel(helpConn) end)
        else
            -- 被打後重置（LastSlappedBy 判定）
            local helpConn = task.spawn(function()
                runHelpLoopRagdollReset(hrp, hum, tgt)
                helpDone = true
            end)
            while not helpDone and toggles.helpTarget do task.wait(0.1) end
            pcall(function() task.cancel(helpConn) end)
        end

        helpDone = true
        pcall(function() task.cancel(noToolThread) end)

        if lobbyStuck and toggles.helpTarget then
            teleportToLobby(hrp)
            task.wait(0.5)
        end
    end
end

