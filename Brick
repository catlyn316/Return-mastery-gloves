local function updateStatus()
    local active = {}
    if toggles.autoBrick      then table.insert(active, "放積木中") end
    if toggles.flying          then table.insert(active, "飛行中") end
    if toggles.positionLocked  then table.insert(active, "位置鎖定") end
    if toggles.noclip          then table.insert(active, "Noclip中") end
    if #active > 0 then
        statusLabel.Text = "✅ " .. table.concat(active, " | ")
        statusLabel.TextColor3 = THEME.accent
    else
        statusLabel.Text = "系統就緒"
        statusLabel.TextColor3 = THEME.primary
    end
end

local function setRowActive(btn, frame, status, isActive, activeText, inactiveText)
    if isActive then
        btn.Text = "解除"
        btn.BackgroundColor3 = Color3.fromRGB(80, 20, 20)
        frame.BackgroundColor3 = Color3.fromRGB(30, 8, 8)
        if status then status.Text = activeText or "運行中"; status.TextColor3 = THEME.accent end
    else
        btn.Text = "啟動"
        btn.BackgroundColor3 = THEME.primary
        frame.BackgroundColor3 = THEME.bgRow
        if status then status.Text = inactiveText or "關閉"; status.TextColor3 = THEME.textMuted end
    end
    updateStatus()
end

