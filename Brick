-- 尋找最近的櫻桃分身 HumanoidRootPart（名稱以 "Cherry " 開頭的模型）
local function findNearestCherryHRP()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = char.HumanoidRootPart.Position

    local nearest, minDist = nil, math.huge
    -- 同時搜尋 Workspace 根層與 cherry_storage
    local containers = {Workspace}
    local cs = Workspace:FindFirstChild("cherry_storage")
    if cs then table.insert(containers, cs) end

    for _, container in ipairs(containers) do
        for _, child in pairs(container:GetChildren()) do
            if child.Name:sub(1, 7) == "Cherry " then
                local hrp = child:FindFirstChild("HumanoidRootPart")
                if hrp and hrp.Parent then
                    local d = (hrp.Position - myPos).Magnitude
                    if d < minDist then
                        minDist = d
                        nearest = hrp
                    end
                end
            end
        end
    end
    return nearest
end

