local function runBrickLoop()
    while toggles.autoBrick do
        pcall(function() ReplicatedStorage.lbrick:FireServer() end)
        brickUseCount = brickUseCount + 1
        if brickCountLabel then
            brickCountLabel.Text = "已使用積木能力: " .. brickUseCount .. " 次"
            brickCountLabel.TextColor3 = THEME.accent
        end
        task.wait(values.brickInterval)
    end
end

local function runPositionLock()
    while toggles.positionLocked do
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            if not originalPosition then
                originalPosition = char.HumanoidRootPart.CFrame
            end
            pcall(function() char.HumanoidRootPart.CFrame = originalPosition end)
        end
        task.wait()
    end
end

local function runHelperPositionLock()
    while toggles.positionLocked do
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            if not originalPosition then
                originalPosition = char.HumanoidRootPart.CFrame
            end
            pcall(function() char.HumanoidRootPart.CFrame = originalPosition end)
        end
        task.wait()
    end
end

local function runNoclip()
    while toggles.noclip do
        local char = player.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
        task.wait(0.1)
    end
end

