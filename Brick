-- ============================================================
-- 攻擊者主循環
-- 邏輯：
--   刷精通關閉 → 每 brickInterval 秒 FireServer lbrick
--   刷精通開啟 → 找最近分身 → 傳送到分身前方並面對 → FireServer lbrick
--             → 找不到分身則暫停等待
-- ============================================================
-- 在指定 CFrame 持續鎖定玩家位置，直到 stopTick 或 toggles.autoBrick 變 false
local function holdPosition(hrp, lockCFrame, stopTick)
    while toggles.autoBrick and tick() < stopTick do
        pcall(function() hrp.CFrame = lockCFrame end)
        task.wait()
    end
end

local function runBrickLoop()
    while toggles.autoBrick do
        local interval = values.brickInterval

        if toggles.masterMode then
            local targetHRP = findNearestCherryHRP()
            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")

            if targetHRP and targetHRP.Parent and hrp then
                -- 計算正上方7單位並面向分身
                local tPos = targetHRP.Position
                local standCF = CFrame.new(tPos + Vector3.new(0, 7, 0), tPos)

                -- 移動過去並鎖定 0.5 秒
                pcall(function() hrp.CFrame = standCF end)
                holdPosition(hrp, standCF, tick() + 0.5)
                if not toggles.autoBrick then break end

                -- 放積木
                pcall(function() ReplicatedStorage.lbrick:FireServer() end)

                -- 鎖定 1.5 秒後再找下一個分身
                holdPosition(hrp, standCF, tick() + 1.5)

            else
                -- 沒有分身：鎖在原地等待直到有分身出現
                if hrp then
                    local holdCF = hrp.CFrame
                    while toggles.autoBrick and toggles.masterMode do
                        pcall(function() hrp.CFrame = holdCF end)
                        task.wait()
                        if findNearestCherryHRP() then break end
                    end
                else
                    task.wait(0.3)
                end
            end
        else
            pcall(function() ReplicatedStorage.lbrick:FireServer() end)
            task.wait(interval)
        end
    end
end

