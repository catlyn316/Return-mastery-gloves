        resetCloneBtn.Text = "停止"; resetCloneBtn.BackgroundColor3 = THEME.red
        r24.BackgroundColor3 = Color3.fromRGB(8, 20, 12)
        activeFeatures["重置分身"] = true; updateStatus()

