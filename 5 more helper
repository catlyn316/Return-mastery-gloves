-- ★ Heartbeat 主執行緒：負責實際發送 FireServer
RunService.Heartbeat:Connect(function()
    if type(onMoreFired) ~= "table" then return end
    local data = onMoreFired
    onMoreFired = false  -- 立刻重設，避免重入

    if not detectRunning then return end

    local remote      = data.remote
    local args        = data.args
    local displayName = data.displayName
    local hitCount    = tonumber(attackCountInput.Text) or 20
    hitCount = math.clamp(math.floor(hitCount), 1, 200)
    local intervalVal = tonumber(attackIntervalInput.Text) or 0.05
    if intervalVal < 0.004 then intervalVal = 0.004 end

    -- 從攔截到的路徑找 _More 資料夾，取最大數字
    -- displayName 例如 "Workspace.玩家名_More.3.Torso"
    -- 從 args 裡找到那個 Instance，往上兩層就是 _More 資料夾
    local moreFolder = nil
    for _, v in ipairs(args) do
        if typeof(v) == "Instance" then
            -- v 是 Torso/Head 等，parent 是數字資料夾，parent.parent 是 _More
            local ok, p = pcall(function() return v.Parent and v.Parent.Parent end)
            if ok and p and p.Name:find("_More") then
                moreFolder = p
                break
            end
            -- 有時候 v 本身就是數字資料夾
            local ok2, pname = pcall(function() return v.Parent and v.Parent.Name end)
            if ok2 and pname and pname:find("_More") then
                moreFolder = v.Parent
                break
            end
        end
    end

    -- 找最大數字
    local maxNum = 0
    if moreFolder then
        for i = 1, 5 do
            if moreFolder:FindFirstChild(tostring(i)) then maxNum = i end
        end
    end

    if maxNum == 0 then
        -- 找不到資料夾就退回只打攔截到的那個
        maxNum = 1
        detectStatusLabel.Text = string.format("攔截！%s x%d", displayName:sub(-30), hitCount)
    else
        detectStatusLabel.Text = string.format("攔截！1~%d x%d", maxNum, hitCount)
    end
    detectStatusLabel.TextColor3 = THEME.green

    -- 主執行緒裡對 1～maxNum 每個都打 hitCount 次
    task.spawn(function()
        for num = 1, maxNum do
            local targetPart = nil
            if moreFolder then
                local numFolder = moreFolder:FindFirstChild(tostring(num))
                if numFolder then
                    -- 用和攔截到的同類部位（Torso/Head 等）
                    for _, v in ipairs(args) do
                        if typeof(v) == "Instance" then
                            local partName = v.Name
                            targetPart = numFolder:FindFirstChild(partName) or numFolder:FindFirstChildOfClass("BasePart") or numFolder
                            break
                        end
                    end
                end
            end

            if targetPart then
                -- 把 args 裡的 Instance 換成對應編號的部位
                local newArgs = {}
                local replaced = false
                for _, v in ipairs(args) do
                    if typeof(v) == "Instance" and not replaced then
                        table.insert(newArgs, targetPart)
                        replaced = true
                    else
                        table.insert(newArgs, v)
                    end
                end
                for i = 1, hitCount do
                    if not detectRunning then break end
                    pcall(function() remote:FireServer(table.unpack(newArgs)) end)
                    if i < hitCount then task.wait(intervalVal) end
                end
            end
        end

        if detectRunning then
            detectStatusLabel.Text = "等待事件中…"
            detectStatusLabel.TextColor3 = THEME.accent
        end
    end)
end)

