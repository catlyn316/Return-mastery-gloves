                if not resetCloneRunning then break end

                pcall(function()
                    ReplicatedStorage.SelfKnockback:FireServer({
                        Direction = Vector3.new(0, 0.01, 0),
                        Force = 0
                    })
                end)
                resetCloneBtn.Text = "停止"
            end
