-- ============================================================
-- __namecall hook：只負責偵測和存資料，不在 hook 裡呼叫 FireServer
-- ============================================================
local onMoreFired = nil  -- hook 偵測到時設為 {remote, args, displayName}

local _nc
_nc = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local results = table.pack(_nc(self, ...))

    if method == "FireServer" and onMoreFired == false then
        -- onMoreFired == false 代表偵測開啟中、等待第一個事件
        local ok, cls = pcall(function() return self.ClassName end)
        if ok and cls == "RemoteEvent" then
            local args = { ... }
            local displayName = self.Name
            for _, v in ipairs(args) do
                if typeof(v) == "Instance" then
                    local ok2, fullName = pcall(function() return v:GetFullName() end)
                    if ok2 and fullName:find("_More") then
                        displayName = fullName
                        -- ★ 只存資料，不碰 FireServer，讓 Heartbeat 主執行緒去打
                        onMoreFired = {remote = self, args = args, displayName = displayName}
                        break
                    end
                end
            end
        end
    end

    return table.unpack(results, 1, results.n)
end))

