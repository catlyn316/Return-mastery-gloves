local function getGloveStat(p)
    local ls = p:FindFirstChild("leaderstats")
    if not ls then return nil end
    local g = ls:FindFirstChild("Glove")
    if not g then return nil end
    return g.Value
end

-- ragdoll 判定：同時檢查多種實作方式
local function isSelfRagdoll()
    local char = player.Character
    if not char then return true end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return true end
    -- 血量為 0
    if hum.Health <= 0 then return true end
    -- Humanoid 狀態倒地
    local state = hum:GetState()
    if state == Enum.HumanoidStateType.FallingDown
    or state == Enum.HumanoidStateType.Ragdoll then
        return true
    end
    -- 角色裡有 Ragdoll 物件（BoolValue/StringValue/Folder 都算）
    if char:FindFirstChild("Ragdoll") then return true end
    -- HumanoidRootPart 被 Anchor（凍結）
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp and hrp.Anchored then return true end
    return false
end

local function getMoreMax(targetName)
    local wsChar = Workspace:FindFirstChild(targetName)
    if not wsChar then return 0 end
    local max = 0
    for i = 1, 5 do
        if wsChar:FindFirstChild(tostring(i) .. "_More") or
           (function()
               local moreFolder = wsChar:FindFirstChild(targetName .. "_More")
               if moreFolder then
                   return moreFolder:FindFirstChild(tostring(i)) ~= nil
               end
               return false
           end)() then
            max = i
        end
    end
    local moreFolder = Workspace:FindFirstChild(targetName .. "_More")
    if not moreFolder then
        moreFolder = wsChar and wsChar:FindFirstChild("More")
    end
    if moreFolder then
        local m = 0
        for i = 1, 5 do
            if moreFolder:FindFirstChild(tostring(i)) then m = i end
        end
        if m > max then max = m end
    end
    return max
end

local function getNearestPlayer()
    local char = player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local nearest, minDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
            if d < minDist then minDist = d nearest = p end
        end
    end
    return nearest
end

